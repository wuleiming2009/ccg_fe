<view class="market-page">
  <view class="promo">
    <text class="promo-title2">GIFTS FOR EVERYDAY MOMENTS</text>
    <text class="promo-title">
      <text class="brand">CC G<text class="bang">!</text>FT</text><text class="mid"> · </text><text class="cn">礼物甄选</text>
    </text>
    <view class="promo-divider"></view>
  </view>
  <view class="card" wx:for="{{items}}" wx:key="index" bindtap="onOpenDetail" data-index="{{index}}">
    <view class="hero">
      <image class="photo" src="{{item.img_url}}" mode="aspectFill"></image>
      <view class="likes-badge {{item.likes > 0 ? 'hot' : 'cold'}}">
        <text class="likes-heart">♥</text>
        <text class="likes-count" wx:if="{{item.likes > 0}}">{{item.likes}}</text>
      </view>
    </view>
    <view class="info">
      <text class="title">{{item.name}}</text>
      <text class="price">￥{{item.price}}</text>
    </view>
    <text class="subtitle">{{item.slogan}}</text>
  </view>
</view>
