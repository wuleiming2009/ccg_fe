.market-page { min-height: 100vh; background: #fefaf9; padding: 12px; padding-bottom: 120rpx; box-sizing: border-box; }
.promo { padding: 14px 4px; margin-bottom: 8px; }
.promo-title2 { display: block; text-align: center; font-size: 12px; letter-spacing: 3px; color: #bdb9b8; text-transform: uppercase; font-weight: 400; }
.promo-title { display: block; text-align: center; font-size: 28px; font-weight: 700; color: #6B6460; letter-spacing: 1px; margin-top: 6px; }
.promo-title .bang { color: #ff7a3f; }
.promo-title .mid { color: #6B6460; }
.promo-title .brand, .promo-title .cn { color: #6B6460; }
.promo-divider { margin: 10px auto 0; width: 92%; height: 1px; background: #d0d7e2; border-radius: 1px; }
.search-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; padding: 0 4px; }
.search-input { flex: 1; height: 36px; background: #FFFFFF; border-radius: 18px; padding: 0 14px; font-size: 14px; box-shadow: inset 0 0 0 1px #E6ECF3; }
.search-btn { padding: 0 16px; height: 36px; line-height: 36px; background: #ff7a3f; color: #FFFFFF; border-radius: 18px; font-size: 14px; }
.card { background: #FFFFFF; border-radius: 10px; overflow: hidden; box-shadow: 0 6px 12px rgba(31,42,55,0.06); margin-bottom: 16px; }
.hero { position: relative; height: 400px; }
.photo { width: 100%; height: 100%; }
.tag { position: absolute; right: 12px; top: 12px; background: #EFF2F6; color: #7A8CA5; font-size: 12px; padding: 4px 8px; border-radius: 999px; letter-spacing: 1px; }
.likes-badge { position: absolute; left: 12px; top: 12px; height: 24px; min-width: 24px; padding: 0 8px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.75); backdrop-filter: blur(6px); }
.likes-heart { font-size: 14px; line-height: 1; }
.likes-count { font-size: 12px; margin-left: 5px; }
.likes-badge.cold .likes-heart { color: rgba(255,255,255,0.95); text-shadow: 0 1px 6px rgba(0,0,0,0.30); }
.likes-badge.hot { background: rgba(255,255,255,0.86); }
.likes-badge.hot .likes-heart, .likes-badge.hot .likes-count { color: #FF4D4F; }
.info { display: flex; justify-content: space-between; align-items: center; padding: 12px 12px 2px 20px; }
.title { font-size: 16px; font-weight: 700; color: #1F2A37; }
.price { font-size: 16px; font-weight: 700; color: #1F2A37; }
.subtitle { display: block; padding: 0 12px 15px 20px; margin-top: 0; font-size: 13px; color: #7A8CA5; }
