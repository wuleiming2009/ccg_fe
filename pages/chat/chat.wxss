/* 页面背景与容器 */
.chat-page { background: #fefaf9; background: #fefaf8; min-height: 100vh; font-family: Inter, Inter;}

.fixed-header {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	background: #fefaf9;
	padding: 32rpx;
	height: 360rpx;
	padding-right: 176rpx;
	box-sizing: border-box;
}

/* 头部 */
.header {
	display: flex;
	align-items: center;
	justify-content: space-between;
}
.header-texts {
	display: flex;
	flex-direction: column;
}
.greeting {
	font-size: 44rpx;
	color: #ff7a3f;
	font-weight: 400;
}
.subtext {
	margin-top: 25rpx;
	font-size: 44rpx;
	color: #ff7a3f;
	width: auto;
	max-width: 100%;
	word-break: break-word;
	
}
.header-illustration {
	position: absolute;
	right: 60rpx;
	top: 4rpx;
}
.avatar-image {
	width: 320rpx;
	height: 400rpx;
	border-radius: 24rpx;
}

/* 中部可滚动区域 */
.chat-scroll {
	height: 100vh;
	padding: 0rpx 24rpx 274rpx;
	padding-bottom: calc(274rpx + constant(safe-area-inset-bottom));
	padding-bottom: calc(274rpx + env(safe-area-inset-bottom));
	box-sizing: border-box;
}
.chat-scroll.no-pills {
	padding-bottom: calc(280rpx + constant(safe-area-inset-bottom));
	padding-bottom: calc(280rpx + env(safe-area-inset-bottom));
}

/* 气泡与标签 */
.messages {
	display: flex;
	flex-direction: column;
	gap: 16rpx;
}
.end-anchor {
	height: 12rpx;
}

/* CTA 样式 */
.conv-hero {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 70rpx 24rpx 0;
	gap: 24rpx;
	margin-bottom: 42rpx;
}
.conv-hero .hero-texts {
	display: flex;
	flex-direction: column;
	gap: 12rpx;
	flex: 1;
	min-width: 0;
}
.hero-gift {
	width: 46%;
	max-width: 362rpx;
	height: 400rpx;
	border-radius: 24rpx;
	flex: none;
}
.messages .bubble:first-of-type {
	margin-top: -40rpx;
}
.cta-wrap {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 16rpx;
	margin-top: 24rpx;
}
.cta-btn {
	background: #000000;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 24rpx 48rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.15);
	width: 84%;
	max-width: 640rpx;
	white-space: nowrap;
	gap: 16rpx;
}
.cta-btn .gift-icon {
	margin-right: 16rpx;
}
.cta-btn .btn-text {
	font-weight: 600;
	white-space: nowrap;
}
.cta-caption {
	font-size: 24rpx;
	color: #9aa4b2;
}
.bubble {
	background: #ffffff;
	border-radius: 28rpx;
	padding: 28rpx;
	margin-top: 28rpx;
	color: #666666;
	line-height: 1.6;
	box-shadow: 0 8rpx 20rpx rgba(31, 42, 55, 0.06);
	max-width: 82%;
}
.left {
	margin-right: 112rpx;
}
.right {
	margin-left: auto;
}

/* 气泡角样式：机器人左下角为直角 */
.bubble.left {
	border-bottom-left-radius: 0;
}

/* 气泡角样式：用户右下角为直角，且颜色为 #FF6B36 */
.bubble.right {
	background: #ff6b36;
	color: #ffffff;
	border-bottom-right-radius: 0;
}

.budget-pill {
	margin: 24rpx 0 0 auto;
	background: #ff7a3f;
	color: #ffffff;
	padding: 16rpx 24rpx;
	border-radius: 999rpx;
	width: fit-content;
	box-shadow: 0 8rpx 20rpx rgba(255, 122, 62, 0.3);
}

/* 底部固定区域 */
.fixed-footer {
	position: fixed;
	left: 0;
	right: 0;
	bottom: calc(98rpx + constant(safe-area-inset-bottom));
	bottom: calc(98rpx + env(safe-area-inset-bottom));
	background: transparent;
	padding: 16rpx 24rpx 0;
	box-sizing: border-box;
	z-index: 1000;
}
.fixed-footer.no-pills {
	height: 180rpx;
	padding-top: 0;
	padding-bottom: 0;
	display: flex;
	flex-direction: column;
	justify-content: center;
}
.fixed-footer.no-pills .footer-bg {
	top: 0;
}
.fixed-footer.no-pills .input-area {
	margin-top: 0;
	transform: translateY(8rpx);
}

.footer-bg {
	position: absolute;
	left: 0;
	right: 0;
	bottom: 0;
	top: 4rpx;
	background: #fefaf9;
	border-top: 2rpx solid rgba(31, 42, 55, 0.06);
	border-bottom: 0;
	z-index: 0;
}

/* 次级操作 */
.secondary-actions {
	position: relative;
	z-index: 2;
	display: flex;
	gap: 4rpx;
	margin-top: 0rpx;
	margin-bottom: 24rpx;
}
.history-pills {
	justify-content: flex-start;
}
.pill {
	display: flex;
	align-items: center;
	gap: 12rpx;
	padding: 20rpx 24rpx;
	border-radius: 999rpx;
	background: #ffffff;
	box-shadow: 0 4rpx 16rpx rgba(31, 42, 55, 0.06);
}
.pill.lite {
	padding: 4rpx 20rpx;
	box-shadow: 0 4rpx 16rpx rgba(31, 42, 55, 0.08);
}
.pill-icon {
	font-size: 32rpx;
}
.pill-text {
	font-size: 28rpx;
}
.pill-text.lite {
	font-size: 26rpx;
	color: #b6b8bb;
}
.pill.blue {
	color: #4a7dff;
}
.pill.orange {
	color: #ff7a3f;
}

.quick-actions {
	display: flex;
	align-items: center;
	gap: 16rpx;
	margin-bottom: 8rpx;
	position: relative;
	z-index: 2;
}
.quick-actions .action-pill:first-of-type {
	margin-left: auto;
}
.ai-tip {
	font-size: 11px;
	color: #B0B0B0;
	flex-shrink: 0;
}
.fixed-footer.no-pills .quick-actions {
	/* margin-bottom: 8px; */
}
.action-pill {
	/* height: 80rpx; */
	padding: 8rpx 20rpx;
	border-radius: 999rpx;
	background: #ffffff;
	color: #666666;
	font-size: 22rpx;
	box-shadow: 0 4rpx 12rpx rgba(31, 42, 55, 0.08);
	border: 2rpx solid #bdb9b8;
	display: inline-flex;
	align-items: center;
}

/* 输入区域 */
.input-area {
	position: relative;
	z-index: 1;
	margin-bottom: 16rpx;
	width: 100%;
}
.fixed-footer .input-area {
	display: flex;
	align-items: center;
	justify-content: flex-end;
	gap: 12rpx;
	margin-top: 20rpx;
}
.input-box {
	position: relative;
	width: 100%;
	height: 280rpx;
	background: #ffffff;
	border-radius: 48rpx;
	border: 2rpx solid #b3b3b3;
	box-sizing: border-box;
}
.voice-btn {
	position: absolute;
	right: 26rpx;
	bottom: 110rpx;
	width: 64rpx;
	height: 64rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}
.voice-img {
	width: 64rpx;
	height: 64rpx;
}
.fixed-footer .voice-btn {
	top: 50%;
	transform: translateY(-50%);
	bottom: auto;
	right: 20rpx;
	width: 56rpx;
	height: 56rpx;
	border-radius: 28rpx;
}
.fixed-footer .voice-img {
	width: 52rpx;
	height: 52rpx;
}
.fixed-footer .voice-input {
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	border-radius: 38rpx;
	display: flex;
	align-items: center;
	padding: 0 92rpx 0 28rpx;
}
.voice-input {
	position: absolute;
	left: 34rpx;
	top: 34rpx;
	right: 128rpx;
	bottom: 34rpx;
	border-radius: 24rpx;
	background: transparent;
	display: flex;
	align-items: center;
	justify-content: center;
	color: #1f2a37;
	font-weight: 600;
	box-shadow: none;
	border: none;
}
.voice-input.recording {
	background: #ff7a3f;
	color: #ffffff;
	box-shadow: none;
}
.input {
	position: absolute;
	left: 34rpx;
	top: 34rpx;
	right: 128rpx;
	bottom: 34rpx;
	width: auto;
	height: auto;
	background: transparent;
	border-radius: 24rpx;
	padding: 0;
	font-size: 32rpx;
	color: #666666;
	box-shadow: none;
	border: none;
}
.fixed-footer .input {
	position: static;
	width: 100%;
	height: 76rpx;
	line-height: 76rpx;
}
.input.ta {
	line-height: 1.5;
	left: 26rpx;
	top: 36rpx;
}
.send-btn {
	width: 64rpx;
	height: 64rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	position: absolute;
	right: 14rpx;
	bottom: 20rpx;
}
.send-btn.circle {
	background: transparent;
	border-radius: 40rpx;
}
.intro-send {
	right: 26rpx;
	bottom: 20rpx;
	top: auto;
	transform: none;
}
.fixed-footer .send-btn {
	width: 72rpx;
	height: 72rpx;
	border-radius: 36rpx;
	flex: none;
	position: relative;
	right: auto;
	bottom: auto;
	align-self: center;
}
.fixed-footer .send-btn.circle.outside {
	background: #ff6b36;
}
.fixed-footer .send-img {
	width: 56rpx;
	height: 56rpx;
}
.fixed-footer .voice-btn {
	z-index: 3;
}
.fixed-footer .send-btn {
	z-index: 3;
}
.header-texts {
	display: flex;
	flex-direction: column;
	margin-left: 32rpx;
	margin-top: 32rpx;
}
.typing {
	display: flex;
	align-items: center;
	gap: 12rpx;
}
.dot {
	width: 12rpx;
	height: 12rpx;
	border-radius: 50%;
	background: rgba(31, 42, 55, 0.6);
	animation: blink 1.2s infinite;
}
.dot:nth-child(2) {
	animation-delay: 0.2s;
}
.dot:nth-child(3) {
	animation-delay: 0.4s;
}
@keyframes blink {
	0% {
		opacity: 0.2;
	}
	50% {
		opacity: 1;
	}
	100% {
		opacity: 0.2;
	}
}

/* 首屏输入层 */
.intro-layer {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background: #fefaf9;
	display: flex;
	align-items: stretch;
	justify-content: flex-start;
	z-index: 20;
}
.intro-bg {
	display: none;
}
.intro-container {
	width: 100%;
	min-height: 100vh;
	position: relative;
	margin: 0 auto;
	display: flex;
	flex-direction: column;
	box-sizing: border-box;
	padding: 24rpx 44rpx;
	padding-top: 93rpx;
}
.intro-center {
	position: relative;
	left: auto;
	right: auto;
	top: auto;
	transform: none;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: flex-start;
	gap: 0;
	flex: 1;
	padding-top: 50rpx;
}
.intro-above {
	display: none;
}
.intro-hero {
	position: relative;
	left: auto;
	right: auto;
	top: auto;
	background: none;
	display: flex;
	flex-direction: column;
	justify-content: flex-start;
	padding: 12rpx;
	box-sizing: border-box;
}

.intro-hero-title {
	width: 328rpx;
	height: 112rpx;
}
.intro-hero-title-img {
	display: flex;
	width: 100%;
	height: 100%;
}
.brand {
	display: flex;
	color: #2f2f2f;
	font-weight: 800;
	font-size: 52rpx;
	letter-spacing: 6rpx;
	font-size: 48rpx;
	font-weight: 700;
	color: #333333;
	letter-spacing: 2rpx;
}
.brand .bang {
	color: #ff7a3f;
