}
.intro-input {
	width: 100%;
	height: 184rpx;
	background: #ffffff;
	border-radius: 32rpx;
	box-shadow: inset 0 0 0 2rpx #e6ecf3;
	padding: 24rpx 28rpx;
	color: #7a8ca5;
}
.intro-actions {
	position: absolute;
	right: 24rpx;
	bottom: 24rpx;
	display: flex;
	gap: 20rpx;
}
.intro-btn {
	width: 72rpx;
	height: 72rpx;
	border-radius: 50%;
	background: #f2f4f7;
	display: flex;
	align-items: center;
	justify-content: center;
}
.intro-icon {
	color: #9aa4b2;
}
.history-scroll {
	width: 100%;
	overflow: hidden;
	position: relative;
	z-index: 2;
}
.history-pills {
	justify-content: flex-start;
	width: max-content;
}
.toggle-img {
	width: 52rpx;
	height: 52rpx;
}
.send-img {
	width: 64rpx;
	height: 64rpx;
}

/* 商品卡片横向选择 */
.prod-hint {
	font-size: 24rpx;
	color: #9aa4b2;
	margin: 4rpx 0 0 16rpx;
}
.prod-list {
	margin-top: 8rpx;
	height: 534rpx;
}
.prod-list swiper {
	background: transparent;
}

.prod-list swiper-item {
	display: flex;
	align-items: center;
	justify-content: center;
	background: transparent;
}

.prod-list .swiper-selected {
	padding-right: 24rpx;
	box-sizing: border-box;
}

.prod-card {
	width: 517rpx;
	height: 482rpx;
	background: #ffffff;
	/* border: 2rpx solid #e6ecf3; */
	border-radius: 36rpx;
	position: relative;
	box-shadow: 0 8rpx 24rpx rgba(31, 42, 55, 0.08);
	transform: scale(0.8);
