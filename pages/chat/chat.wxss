/* 页面背景与容器 */
.chat-page {
	background: #fefaf9;
	background: #fefaf8;
	min-height: 100vh;
	font-family: Inter, Inter;
}

.fixed-header {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	background: #fefaf9;
	padding: 16px;
	height: 180px;
	padding-right: 88px;
	box-sizing: border-box;
}

/* 头部 */
.header {
	display: flex;
	align-items: center;
	justify-content: space-between;
}
.header-texts {
	display: flex;
	flex-direction: column;
}
.greeting {
	font-size: 22px;
	color: #ff7a3f;
	font-weight: 400;
}
.subtext {
	margin-top: 16px;
	font-size: 22px;
	color: #ff7a3f;
	width: auto;
	max-width: 100%;
	word-break: break-word;
}
.header-illustration {
	position: absolute;
	right: 30px;
	top: 2px;
}
.avatar-image {
	width: 160px;
	height: 200px;
	border-radius: 12px;
}

/* 中部可滚动区域 */
.chat-scroll {
	height: 100vh;
	padding: 0px 12px 88px;
	padding-bottom: calc(88px + constant(safe-area-inset-bottom));
	padding-bottom: calc(88px + env(safe-area-inset-bottom));
	box-sizing: border-box;
}
.chat-scroll.no-pills {
	padding-bottom: calc(56px + constant(safe-area-inset-bottom));
	padding-bottom: calc(56px + env(safe-area-inset-bottom));
}

/* 气泡与标签 */
.messages {
	display: flex;
	flex-direction: column;
	gap: 8px;
}
.end-anchor {
	height: 6px;
}

/* CTA 样式 */
.conv-hero {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 0 12px 0;
	gap: 12px;
}
.conv-hero .hero-texts {
	display: flex;
	flex-direction: column;
	gap: 6px;
	flex: 1;
	min-width: 0;
}
.hero-gift {
	width: 46%;
	max-width: 181px;
	height: 200px;
	border-radius: 12px;
	flex: none;
}
.messages .bubble:first-of-type {
	margin-top: -20px;
}
.cta-wrap {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 8px;
	margin-top: 12px;
}
.cta-btn {
	background: #000000;
	color: #ffffff;
	border-radius: 999px;
	padding: 12px 24px;
	display: flex;
	align-items: center;
	justify-content: center;
	box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
	width: 84%;
	max-width: 320px;
	white-space: nowrap;
	gap: 8px;
}
.cta-btn .gift-icon {
	margin-right: 8px;
}
.cta-btn .btn-text {
	font-weight: 600;
	white-space: nowrap;
}
.cta-caption {
	font-size: 12px;
	color: #9aa4b2;
}
.bubble {
	background: #ffffff;
	border-radius: 14px;
	padding: 14px;
	margin-top: 14px;
	color: #666666;
	line-height: 1.6;
	box-shadow: 0 4px 10px rgba(31, 42, 55, 0.06);
	max-width: 82%;
}
.left {
	margin-right: 56px;
}
.right {
	margin-left: auto;
}

/* 气泡角样式：机器人左下角为直角 */
.bubble.left {
	border-bottom-left-radius: 0;
}

/* 气泡角样式：用户右下角为直角，且颜色为 #FF6B36 */
.bubble.right {
	background: #ff6b36;
	color: #ffffff;
	border-bottom-right-radius: 0;
}

.budget-pill {
	margin: 12px 0 0 auto;
	background: #ff7a3f;
	color: #ffffff;
	padding: 8px 12px;
	border-radius: 999px;
	width: fit-content;
	box-shadow: 0 4px 10px rgba(255, 122, 62, 0.3);
}

/* 底部固定区域 */
.fixed-footer {
	position: fixed;
	left: 0;
	right: 0;
	bottom: 0px;
	background: transparent;
	padding: 8px 12px 0;
	box-sizing: border-box;
	z-index: 10;
}
.fixed-footer.no-pills {
	height: 60px;
	padding-top: 0;
	padding-bottom: 0;
	display: flex;
	flex-direction: column;
	justify-content: center;
}
.fixed-footer.no-pills .footer-bg {
	top: 0;
}
.fixed-footer.no-pills .input-area {
	margin-top: 0;
	transform: translateY(4px);
}

.footer-bg {
	position: absolute;
	left: 0;
	right: 0;
	bottom: 0;
	top: 2px;
	background: #fefaf9;
	border-top: 1px solid rgba(31, 42, 55, 0.06);
	border-bottom: 0;
	z-index: 0;
}

/* 次级操作 */
.secondary-actions {
	position: relative;
	z-index: 2;
	display: flex;
	gap: 2px;
	margin-top: 0px;
	margin-bottom: 12px;
}
.history-pills {
	justify-content: flex-start;
}
.pill {
	display: flex;
	align-items: center;
	gap: 6px;
	padding: 10px 12px;
	border-radius: 999px;
	background: #ffffff;
	box-shadow: 0 2px 8px rgba(31, 42, 55, 0.06);
}
.pill.lite {
	padding: 2px 10px;
	box-shadow: 0 2px 8px rgba(31, 42, 55, 0.08);
}
.pill-icon {
	font-size: 16px;
}
.pill-text {
	font-size: 14px;
}
.pill-text.lite {
	font-size: 13px;
	color: #b6b8bb;
}
.pill.blue {
	color: #4a7dff;
}
.pill.orange {
	color: #ff7a3f;
}

/* 输入区域 */
.input-area {
	position: relative;
	z-index: 1;
	margin-bottom: 16rpx;
	width: 100%;
}
.fixed-footer .input-area {
	display: flex;
	align-items: center;
	justify-content: flex-end;
	gap: 6px;
	margin-top: 10px;
}
.input-box {
	position: relative;
	width: 100%;
	height: 280rpx;
	background: #ffffff;
	border-radius: 48rpx;
	/* box-shadow: 0 2px 8px rgba(31, 42, 55, 0.06); */
	border: 2rpx solid #b3b3b3;
	box-sizing: border-box;
}
.voice-btn {
	position: absolute;
	right: 26rpx;
	bottom: 110rpx;
	width: 64rpx;
	height: 64rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	/* border-radius: 20px; */
}
.voice-img {
	width: 64rpx;
	height: 64rpx;
}
.fixed-footer .voice-btn {
	top: 50%;
	transform: translateY(-50%);
	bottom: auto;
	right: 10px;
	width: 28px;
	height: 28px;
	border-radius: 14px;
}
.fixed-footer .voice-img {
	width: 26px;
	height: 26px;
}
.fixed-footer .voice-input {
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	border-radius: 19px;
	display: flex;
	align-items: center;
	padding: 0 46px 0 14px;
}
.voice-input {
	position: absolute;
	left: 17px;
	top: 17px;
	right: 64px;
	bottom: 17px;
	border-radius: 12px;
	background: transparent;
	display: flex;
	align-items: center;
	justify-content: center;
	color: #1f2a37;
	font-weight: 600;
	box-shadow: none;
	border: none;
}
.voice-input.recording {
	background: #ff7a3f;
	color: #ffffff;
	box-shadow: none;
}
.input {
	position: absolute;
	left: 17px;
	top: 17px;
	right: 64px;
	bottom: 17px;
	width: auto;
	height: auto;
	background: transparent;
	border-radius: 12px;
	padding: 0;
	font-size: 16px;
	color: #666666;
	box-shadow: none;
	border: none;
}
.fixed-footer .input {
	position: static;
	width: 100%;
	height: 38px;
	line-height: 38px;
}
.input.ta {
	line-height: 1.5;
	left: 26rpx;
	top: 36rpx;
}
.send-btn {
	width: 64rpx;
	height: 64rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	position: absolute;
	right: 7px;
	bottom: 10px;
}
.send-btn.circle {
	background: transparent;
	border-radius: 20px;
}
.intro-send {
	right: 26rpx;
	bottom: 20rpx;
	top: auto;
	transform: none;
}
.fixed-footer .send-btn {
	width: 36px;
	height: 36px;
	border-radius: 18px;
	flex: none;
	position: relative;
	right: auto;
	bottom: auto;
	align-self: center;
}
.fixed-footer .send-btn.circle.outside {
	background: #ff6b36;
}
.fixed-footer .send-img {
	width: 28px;
	height: 28px;
}
.fixed-footer .voice-btn {
	z-index: 3;
}
.fixed-footer .send-btn {
	z-index: 3;
}
.header-texts {
	display: flex;
	flex-direction: column;
	margin-left: 16px;
	margin-top: 16px;
}
.typing {
	display: flex;
	align-items: center;
	gap: 6px;
}
.dot {
	width: 6px;
	height: 6px;
	border-radius: 50%;
	background: rgba(31, 42, 55, 0.6);
	animation: blink 1.2s infinite;
}
.dot:nth-child(2) {
	animation-delay: 0.2s;
}
.dot:nth-child(3) {
	animation-delay: 0.4s;
}
@keyframes blink {
	0% {
		opacity: 0.2;
	}
	50% {
		opacity: 1;
	}
	100% {
		opacity: 0.2;
	}
}
