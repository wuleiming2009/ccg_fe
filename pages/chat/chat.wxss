	z-index: 1;
	margin: 0 auto;
	overflow: hidden;
}
.prod-card.selected {
	transform: scale(1);
	box-shadow: 12rpx 12rpx 20rpx rgba(31, 42, 55, 0.5);
	z-index: 2;
}
.header-band {
	position: relative;
	height: 98rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}
.band-bg {
	position: absolute;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	width: 100%;
	height: 100%;
	z-index: 0;
}
.band-texts {
	position: relative;
	z-index: 3;
	width: 100%;
	height: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: space-between;
	padding: 18rpx 12rpx 12rpx;
	box-sizing: border-box;
