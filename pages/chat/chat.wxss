	background: #ffffff;
	box-shadow: 0 4rpx 16rpx rgba(31, 42, 55, 0.12);
}
.pill-btn.overlay {
	position: absolute;
	left: 20rpx;
	bottom: 48rpx;
}

/* 轻操作 */
.light-actions {
	/* margin-top: 8rpx; */
	display: flex;
	gap: 16rpx;
	justify-content: space-between;
}
.light-btn {
	flex: 1;
	border-radius: 999rpx;
	padding: 16rpx 20rpx;
	font-size: 26rpx;
}
.light-btn.orange {
	background: #ff7a3f;
	color: #ffffff;
	border: none;
}
.light-btn.gray {
	background: #f4f6f8;
	color: #1f2a37;
	border: none;
}
.light-btn.outline {
	background: #ffffff;
	color: #ff7a3f;
	border: 2rpx solid #ff7a3f;
}
