/* 页面背景与容器 */
.chat-page {
  background: #fefaf9;
  min-height: 100vh;
}

.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fefaf9;
  padding: 16px;
  height: 180px;
  padding-right: 88px;
  box-sizing: border-box;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.header-texts {
  display: flex;
  flex-direction: column;
}
.greeting {
  font-size: 22px;
  color: #ff7a3f;
  font-weight: 400;
}
.subtext {
  margin-top: 16px;
  font-size: 22px;
  color: #ff7a3f;
  width: 150px;
}
.header-illustration {
  position: absolute;
  right: 30px;
  top: 2px;
}
.avatar-image {
  width: 160px;
  height: 200px;
  border-radius: 12px;
}

/* 中部可滚动区域 */
.chat-scroll {
  height: 100vh;
  padding: 0px 12px 88px;
  box-sizing: border-box;
}
.chat-scroll.no-pills { padding-bottom: 56px; }

/* 气泡与标签 */
.messages { display: flex; flex-direction: column; gap: 8px; }
.end-anchor { height: 6px; }

/* CTA 样式 */
.conv-hero { display: flex; align-items: center; justify-content: space-between; padding: 0 12px 0; }
.conv-hero .hero-texts { display: flex; flex-direction: column; gap: 6px; }
.hero-gift { width: 181px; height: 200px; border-radius: 12px; }
.messages .bubble:first-of-type { margin-top: -20px; }
.cta-wrap { display: flex; flex-direction: column; align-items: center; gap: 8px; margin-top: 12px; }
.cta-btn { background: #000000; color: #FFFFFF; border-radius: 999px; padding: 12px 24px; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 12px rgba(0,0,0,0.15); min-width: 260px; white-space: nowrap; gap: 8px; }
.cta-btn .gift-icon { margin-right: 8px; }
.cta-btn .btn-text { font-weight: 600; white-space: nowrap; }
.cta-caption { font-size: 12px; color: #9AA4B2; }
.bubble {
  background: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  margin-top: 14px;
  color: #666666;
  line-height: 1.6;
  box-shadow: 0 4px 10px rgba(31,42,55,0.06);
  max-width: 82%;
}
.left { margin-right: 56px; }
.right { margin-left: auto; }

/* 气泡角样式：机器人左下角为直角 */
.bubble.left {
  border-bottom-left-radius: 0;
}

/* 气泡角样式：用户右下角为直角，且颜色为 #FF6B36 */
.bubble.right {
  background: #FF6B36;
  color: #FFFFFF;
  border-bottom-right-radius: 0;
}

.budget-pill {
  margin: 12px 0 0 auto;
  background: #ff7a3f;
  color: #FFFFFF;
  padding: 8px 12px;
  border-radius: 999px;
  width: fit-content;
  box-shadow: 0 4px 10px rgba(255, 122, 62, 0.3);
}

/* 底部固定区域 */
.fixed-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0px;
  background: transparent;
  padding: 8px 12px 8px;
  box-sizing: border-box;
  z-index: 10;
}
.fixed-footer.no-pills .footer-bg { top: 8px; }

.footer-bg {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 2px;
  background: #fefaf9;
  border-top: 1px solid rgba(31,42,55,0.06);
  border-bottom: 0;
  z-index: 0;
}

/* 次级操作 */
.secondary-actions {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 2px;
  margin-top: 0px;
  margin-bottom: 12px;
}
.history-pills { justify-content: flex-start; }
.pill {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 12px;
  border-radius: 999px;
  background: #FFFFFF;
  box-shadow: 0 2px 8px rgba(31,42,55,0.06);
}
.pill.lite { padding: 2px 10px; box-shadow: 0 2px 8px rgba(31,42,55,0.08); }
.pill-icon { font-size: 16px; }
.pill-text { font-size: 14px; }
.pill-text.lite { font-size: 13px; color: #b6b8bb; }
.pill.blue { color: #4A7DFF; }
.pill.orange { color: #ff7a3f; }

/* 输入区域 */
.input-area {
  position: relative;
  z-index: 1;
  margin-top: 8px;
  width: 100%;
}
.input-box {
  position: relative;
  width: 100%;
  height: 164px;
  background: #FFFFFF;
  border-radius: 18px;
  box-shadow: 0 2px 8px rgba(31,42,55,0.06);
  border: 1px solid #bdb9b8;
  box-sizing: border-box;
}
.voice-btn {
  position: absolute;
  right: 7px;
  bottom: 55px;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24px;
}
.voice-img { width: 40px; height: 40px; }
.fixed-footer .voice-btn { bottom: 5px; width: 36px; height: 36px; border-radius: 18px; }
.fixed-footer .voice-img { width: 40px; height: 40px; }
.fixed-footer .voice-input { left: 12px; right: 46px; top: 12px; bottom: 12px; border-radius: 22px; }
.voice-input {
  position: absolute;
  left: 17px;
  top: 17px;
  right: 64px;
  bottom: 17px;
  border-radius: 12px;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1F2A37;
  font-weight: 600;
  box-shadow: none;
  border: none;
}
.voice-input.recording { background: #ff7a3f; color: #FFFFFF; box-shadow: none; }
.input {
  position: absolute;
  left: 17px;
  top: 17px;
  height: 130px;
  width: 310px;
  background: transparent;
  border-radius: 12px;
  padding: 0;
  font-size: 16px;
  color: #666666;
  box-shadow: none;
  border: none;
}
.fixed-footer .input { left: 12px; top: 8px; width: 298px; height: 30px; right: auto; bottom: auto; }
.input.ta { line-height: 1.5; }
.send-btn {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  right: 7px;
  bottom: 10px;
}
.send-btn.circle {
  background: transparent;
  border-radius: 24px;
}
.intro-send { right: 7px; bottom: 10px; top: auto; transform: none; }
.fixed-footer .send-btn { bottom: 3px; width: 40px; height: 40px; border-radius: 20px; }
.fixed-footer .send-img { width: 40px; height: 40px; }
.fixed-footer .send-btn { right: -50px; z-index: 3; }
.header-texts {
  display: flex;
  flex-direction: column;
  margin-left: 16px;
  margin-top: 16px;
}
.typing { display: flex; align-items: center; gap: 6px; }
.dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(31,42,55,0.6); animation: blink 1.2s infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink { 0% { opacity: 0.2 } 50% { opacity: 1 } 100% { opacity: 0.2 } }
/* 首屏输入层 */
.intro-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: #fefaf9;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  z-index: 20;
}
.intro-bg { display: none; }
.intro-container { width: 98vw; min-height: 100vh; position: relative; margin: 0 auto; }
.intro-center { position: absolute; left: 0; right: 0; top: 55%; transform: translateY(-50%); display: flex; flex-direction: column; align-items: center; gap: 0; }
.intro-center { padding: 0 12px; }
.intro-above { display: none; }
.intro-hero { position: absolute; left: 0; right: 0; top: 0; background: none; display: flex; flex-direction: column; justify-content: flex-start; padding: 24px; box-sizing: border-box; }
.brand { color: #2F2F2F; font-weight: 800; font-size: 26px; letter-spacing: 3px; }
.brand .bang { color: #ff7a3f; }
.tagline { margin-top: 50px; color: #ff7a3f; font-size: 12px; letter-spacing: 3px; text-transform: uppercase; font-weight: 400; }
.greet-row { margin-top: 35px; display: flex; align-items: baseline; gap: 6px; line-height: 1.2; }
.Hi { color: #6B6460; font-size: 40px; font-weight: 400; font-family: Georgia, 'Times New Roman', serif; }
.name { color: #6B6460; font-size: 40px; font-weight: 400; font-family: Georgia, 'Times New Roman', serif; }
.ask-row { margin-top: 8px; display: flex; align-items: baseline; flex-wrap: wrap; line-height: 1.2; }
.ask-strong { color: #ff7a3f; font-size: 40px; font-weight: 400; letter-spacing: 1px; font-family: Georgia, 'Times New Roman', serif; }
.ask-rest { color: #6B6460; font-size: 40px; font-weight: 400; font-family: Georgia, 'Times New Roman', serif; }
.prompt-line { margin-bottom: 0; height: 0; }
.prompt-text { font-size: 0; }
.intro-card {
  width: 100%;
  height: 20px;
  background: #FFFFFF;
  border-radius: 24px;
  box-shadow: 0 8px 20px rgba(31,42,55,0.10);
  border: none;
  position: relative;
  box-sizing: border-box;
  z-index: 1;
}
.quick-caps { margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap; }
.cap { height: 40px; padding: 0 12px; border-radius: 999px; background: #FFFFFF; color: #666666; font-size: 16px; box-shadow: 0 2px 6px rgba(31,42,55,0.08); border: 1px solid #bdb9b8; display: inline-flex; align-items: center; justify-content: center; box-sizing: border-box; }
.caps-input { width: 385px; margin: 0 auto; display: flex; flex-direction: column; align-items: stretch; }
.quick-caps-out { margin: 10px 0 12px; display: flex; justify-content: flex-start; gap: 10px; flex-wrap: wrap; width: 100%; }
.caps-input .input-box { width: 385px; margin: 0 auto; }
.fixed-footer .input-box { width: 360px; height: 46px; border-radius: 35px; }
.quick-caps-out .cap { display: inline-flex; width: auto; min-width: 80px; text-align: center; }
.intro-banner {
  width: 100%;
  height: 200px;
  border-radius: 18px;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 6px 16px rgba(31,42,55,0.06);
  border: 2px solid #E0E7FF;
  box-sizing: border-box;
}
.intro-banner swiper { width: 100%; height: 100%; }
.banner-image { width: 100%; height: 100%; }
.discount-card {
  margin: 0 2px;
  width: calc(100% - 20px);
  display: flex;
  align-items: center;
  gap: 10px;
  background: #FFF3E8;
  border-radius: 16px;
  padding: 10px 12px;
}
.discount-icon { font-size: 18px; }
.discount-text { flex: 1; color: #1F2A37; font-size: 14px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.discount-action { color: #ff7a3f; font-weight: 600; }
.intro-input {
  width: 100%;
  height: 92px;
  background: #FFFFFF;
  border-radius: 16px;
  box-shadow: inset 0 0 0 1px #E6ECF3;
  padding: 12px 14px;
  color: #7A8CA5;
}
.intro-actions {
  position: absolute;
  right: 12px;
  bottom: 12px;
  display: flex;
  gap: 10px;
}
.intro-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #F2F4F7;
  display: flex;
  align-items: center;
  justify-content: center;
}
.intro-icon { color: #9AA4B2; }
.history-scroll { width: 100%; overflow: hidden; position: relative; z-index: 2; }
.history-pills { justify-content: flex-start; width: max-content; }
.toggle-img { width: 26px; height: 26px; }
.send-img { width: 40px; height: 40px; }

/* 商品卡片横向选择 */
.prod-hint { font-size: 12px; color: #9AA4B2; margin: 2px 0 0 8px; }
.prod-list { margin-top: 4px; height: 284px; }
.prod-list swiper { background: transparent; }
.prod-list swiper-item { display: flex; align-items: center; justify-content: center; background: transparent; }
.prod-card {
  width: 282px;
  height: 264px;
  background: #FFFFFF;
  border: 1px solid #E6ECF3;
  border-radius: 18px;
  position: relative;
  box-shadow: none;
  transform: scale(1);
  transform-origin: center;
  transition: transform .25s ease, box-shadow .25s ease;
  z-index: 1;
  margin: 0 auto;
  overflow: hidden;
}
.prod-card.selected { transform: scale(1); box-shadow: none; z-index: 2; }
.header-band { position: relative; height: 90px; display: flex; align-items: center; justify-content: center; }
.band-bg { position: absolute; left: 0; right: 0; top: 0; bottom: 0; width: 100%; height: 100%; z-index: 0; }
.band-texts { position: relative; z-index: 3; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0 6px; box-sizing: border-box; transform: translateY(-14px); }
.band-title { color: #666666; font-weight: 700; font-size: 16px; text-align: center; white-space: normal; word-break: break-word; overflow-wrap: anywhere; }
.band-sub { color: #666666; font-size: 12px; margin-top: 2px; text-align: center; white-space: normal; word-break: break-word; overflow-wrap: anywhere; }
.image-area { position: absolute; left: 0; right: 0; bottom: 0; height: 244px; z-index: 2; }
.card-image { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; height: 210px; background: transparent; }
.card-actions { display: flex; align-items: center; justify-content: flex-start; padding: 10px; }
.pill-btn { border: 2px solid #ff7a3f; color: #ff7a3f; border-radius: 999px; padding: 6px 12px; font-size: 13px; background: #FFFFFF; box-shadow: 0 2px 8px rgba(31,42,55,0.12); }
.pill-btn.overlay { position: absolute; left: 10px; bottom: 24px; }

/* 轻操作 */
.light-actions { margin-top: 4px; display: flex; gap: 8px; justify-content: space-between; }
.light-btn { flex: 1; border-radius: 999px; padding: 8px 10px; font-size: 13px; }
.light-btn.orange { background: #ff7a3f; color: #FFFFFF; border: none; }
.light-btn.gray { background: #F4F6F8; color: #1F2A37; border: none; }
.light-btn.outline { background: #FFFFFF; color: #ff7a3f; border: 1px solid #ff7a3f; }
