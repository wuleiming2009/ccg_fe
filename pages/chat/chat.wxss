	left: 10px;
	bottom: 24px;
}

/* 轻操作 */
.light-actions {
	margin-top: 4px;
	display: flex;
	gap: 8px;
	justify-content: space-between;
}
.light-btn {
	flex: 1;
	border-radius: 999px;
	padding: 8px 10px;
	font-size: 13px;
}
.light-btn.orange {
	background: #ff7a3f;
	color: #ffffff;
	border: none;
}
.light-btn.gray {
	background: #f4f6f8;
	color: #1f2a37;
	border: none;
}
.light-btn.outline {
	background: #ffffff;
	color: #ff7a3f;
	border: 1px solid #ff7a3f;
}
