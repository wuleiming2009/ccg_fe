	font-size: 20rpx;
	font-weight: 400;
	text-align: center;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;

}
.image-area {
	position: absolute;
	left: 0;
	right: 0;
	bottom: 0;
	height: 384rpx;
	z-index: 2;
}
.card-image {
	position: absolute;
	left: 0;
	right: 0;
	bottom: 0;
	width: 100%;
	height: 384rpx;
	background: transparent;
}
.card-actions {
	display: flex;
	align-items: center;
	justify-content: flex-start;
	padding: 20rpx;
}
.pill-btn {
	border: 4rpx solid #ff7a3f;
	color: #ff7a3f;
	border-radius: 999rpx;
	padding: 12rpx 24rpx;
