}
.tagline {
	margin-top: 24rpx;
	color: #ff7a3f;
	font-size: 24rpx;
	letter-spacing: 6rpx;
	text-transform: uppercase;
	font-weight: 400;
	font-size: 24rpx;
	font-weight: 400;
	color: #ff8c42;
	letter-spacing: 1rpx;
}
.greet-row {
	margin-top: 42rpx;
	display: flex;
	align-items: baseline;
	gap: 12rpx;
	line-height: 74rpx;
	font-family: Inter, Inter;
	font-size: 60rpx;
	color: #6d6158;
}
.Hi {
	margin-right: 10rpx;
}
.ask-row {
	margin-top: 20rpx;
	width: 456rpx;
	height: 78rpx;
}
.ask-strong {
	color: #ff7a3f;
	font-size: 72rpx;
	font-weight: 400;
	letter-spacing: 2rpx;
	font-family: Georgia, "Times New Roman", serif;
	font-size: 48rpx;
	font-weight: 700;
	color: #ff8c42;
}
.ask-rest {
	color: #6b6460;
	font-size: 72rpx;
	font-weight: 400;
	font-family: Georgia, "Times New Roman", serif;
	font-size: 48rpx;
	font-weight: 700;
	color: #333333;
}
.prompt-line {
	margin-bottom: 0;
	height: 0;
}
.prompt-text {
	font-size: 0;
}
.intro-card {
	width: 100%;
	height: 40rpx;
	background: #ffffff;
	border-radius: 48rpx;
	box-shadow: 0 16rpx 40rpx rgba(31, 42, 55, 0.1);
	border: none;
	position: relative;
	box-sizing: border-box;
	z-index: 1;
}
.quick-caps {
	margin-top: 20rpx;
	display: flex;
	gap: 16rpx;
	flex-wrap: wrap;
}
.cap {
	height: 80rpx;
	padding: 0 24rpx;
	border-radius: 999rpx;
	background: #ffffff;
	color: #666666;
	font-size: 32rpx;
	box-shadow: 0 4rpx 12rpx rgba(31, 42, 55, 0.08);
	border: 2rpx solid #bdb9b8;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	box-sizing: border-box;
}
.caps-input {
	width: 100%;
	max-width: 100%;
	margin: 0 auto;
	display: flex;
	flex-direction: column;
	align-items: stretch;
	position: relative;
}
.quick-caps-out {
	margin: 12rpx 0 20rpx;
	display: flex;
	justify-content: flex-start;
	gap: 20rpx;
	flex-wrap: wrap;
	width: 100%;
	display: flex;
	flex-wrap: wrap;
	gap: 16rpx;
	margin-bottom: 32rpx;
}
.caps-input .input-box {
	width: 100%;
	margin: 0 auto;
}
.fixed-footer .input-box {
	width: auto;
	max-width: none;
	flex: 1;
	min-width: 0;
	height: 76rpx;
	border-radius: 38rpx;
	display: flex;
	align-items: center;
	padding: 0 92rpx 0 28rpx;
}
.quick-caps-out .cap {
	padding: 0rpx 32rpx;
	background: #ffffff;
	border: 2rpx solid #b3b3b3;
	border-radius: 80rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	transition: all 0.3s ease;
	color: #6d6158;
	font-size: 23rpx;
	height: 66rpx;
}
.quick-caps-out .cap.active {
	color: #ff7a3f;
	border-color: #ff7a3f;
	background: #fcf3ea;
}
.intro-banner {
	width: 100%;
	height: 400rpx;
	border-radius: 36rpx;
	overflow: hidden;
	background: #ffffff;
	box-shadow: 0 12rpx 32rpx rgba(31, 42, 55, 0.06);
	border: 4rpx solid #e0e7ff;
	box-sizing: border-box;
}
.intro-banner swiper {
	width: 100%;
	height: 100%;
}
.banner-image {
	width: 100%;
	height: 100%;
}
.discount-card {
	margin: 0 4rpx;
	width: calc(100% - 40rpx);
	display: flex;
	align-items: center;
	gap: 20rpx;
	background: #fff3e8;
