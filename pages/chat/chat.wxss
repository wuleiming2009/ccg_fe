/* 商品卡片横向选择 */
.prod-hint {
	font-size: 12px;
	color: #9aa4b2;
	margin: 2px 0 0 8px;
}
.prod-list {
	margin-top: 4px;
	height: 284px;
}
.prod-list swiper {
	background: transparent;
}
.prod-list swiper-item {
	display: flex;
	align-items: center;
	justify-content: center;
	background: transparent;
}
.prod-card {
	width: 282px;
	height: 264px;
	background: #ffffff;
	border: 1px solid #e6ecf3;
	border-radius: 18px;
	position: relative;
	box-shadow: none;
	transform: scale(1);
	transform-origin: center;
	transition:
		transform 0.25s ease,
		box-shadow 0.25s ease;
	z-index: 1;
	margin: 0 auto;
	overflow: hidden;
}
.prod-card.selected {
	transform: scale(1);
	box-shadow: none;
	z-index: 2;
}
.header-band {
	position: relative;
	height: 90px;
	display: flex;
	align-items: center;
	justify-content: center;
}
.band-bg {
	position: absolute;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	width: 100%;
	height: 100%;
	z-index: 0;
}
.band-texts {
	position: relative;
	z-index: 3;
	width: 100%;
	height: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	padding: 0 6px;
	box-sizing: border-box;
	transform: translateY(-14px);
}
.band-title {
	color: #666666;
	font-weight: 700;
	font-size: 16px;
	text-align: center;
	white-space: normal;
	word-break: break-word;
	overflow-wrap: anywhere;
}
.band-sub {
