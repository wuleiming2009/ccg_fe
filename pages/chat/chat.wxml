<view class="chat-page">
  <block wx:if="{{introMode}}">
    <view class="intro-layer">
      <view class="intro-container">
        <view class="intro-hero">
          <view class="intro-hero-title">
            <image class="intro-hero-title-img" src="https://wumuxuan-1253516064.cos.ap-shanghai.myqcloud.com/ccg/uni-app/home_title.png"></image>
          </view>
          <!-- <view class="brand">
            CC G
            <view class="bang">!</view>
            FT
          </view>
          <text class="tagline">FOR SOMEONE SPECIAL</text> -->
          <view class="greet-row">
            <text class="Hi">Hi</text>
            <text class="name">{{userName ? userName : ''}}</text>
          </view>
          <view class="ask-row">
            <image class="intro-hero-title-img" src="https://wumuxuan-1253516064.cos.ap-shanghai.myqcloud.com/ccg/uni-app/home_desc.png"></image>
            <!-- <text class="ask-strong">有什么</text>
            <text class="ask-rest">想聊聊吗？</text> -->
          </view>
        </view>
        <view class="intro-center">
          <view class="prompt-line">
            <text class="prompt-text"></text>
          </view>
          <view class="caps-input">
            <view class="input-area">
              <view class="input-box">
                <block wx:if="{{!voiceMode}}">
                  <textarea class="input ta" placeholder="{{introPlaceholder}}" placeholder-style="color:#b3b3b3" value="{{inputValue}}" bindinput="onIntroInput" />
                </block>
                <block wx:else>
                  <view class="voice-input {{recording ? 'recording' : ''}}" bindtouchstart="onVoiceStart" bindtouchend="onVoiceEnd" bindtouchcancel="onVoiceCancel">
                    <text class="voice-text">{{voiceHint}}</text>
                  </view>
                </block>
                <view class="voice-btn" bindtap="onToggleVoiceMode">
                  <image class="voice-img" src="{{voiceMode ? '../../images/text.png' : '../../images/voice.png'}}" mode="aspectFit"></image>
                </view>
                <view class="send-btn circle intro-send" bindtap="onIntroSend">
                  <image class="send-img" src="../../images/send.png" mode="aspectFit"></image>
                </view>
              </view>
            </view>
            <view class="quick-caps-out">
              <view class="cap" data-text="送自己" bindtap="onQuickCapsule">送自己</view>
              <view class="cap" data-text="送爱人" bindtap="onQuickCapsule">送爱人</view>
              <view class="cap" data-text="送长辈" bindtap="onQuickCapsule">送长辈</view>
              <view class="cap" data-text="送闺蜜" bindtap="onQuickCapsule">送闺蜜</view>
              <view class="cap" data-text="送客户" bindtap="onQuickCapsule">送客户</view>
              <view class="cap" data-text="吵架后" bindtap="onQuickCapsule">吵架后</view>
              <view class="cap" data-text="第一次见" bindtap="onQuickCapsule">第一次见</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
  <view class="fixed-header" wx:if="{{false}}"></view>
  <scroll-view wx:if="{{!introMode}}" class="chat-scroll {{hasPills ? '' : 'no-pills'}}" scroll-y="true" scroll-with-animation="true" scroll-into-view="{{scrollInto}}">
    <view class="messages">
      <view class="conv-hero">
        <view class="hero-texts">
          <text class="greeting">{{greeting}}</text>
          <text class="subtext">{{welcomStr}}</text>
        </view>
      </view>
      <block wx:for="{{messages}}" wx:key="index">
        <block wx:if="{{item.type === 'products'}}">
          <swiper class="prod-list" previous-margin="108rpx" next-margin="108rpx" circular="true" indicator-dots="{{false}}" duration="400" easing-function="ease" current="{{item.current || 0}}" data-mid="{{item._id}}" bindchange="onProdSwiperChange">
            <swiper-item wx:for="{{item.products}}" wx:for-item="prod" wx:for-index="pidx" wx:key="pidx" class="{{(item.current || 0) == pidx ? 'swiper-selected' : ''}}">
              <view class="prod-card {{(item.current || 0) == pidx ? 'selected' : ''}}" bindtap="selectProduct" data-index="{{pidx}}">
                <view class="header-band">
                  <view class="band-texts">
                    <view class="band-title">{{prod.name}}</view>
                    <view class="band-sub">{{prod.match_meaning || ''}}</view>
                  </view>
                </view>
                <view class="image-area">
                  <image class="card-image" src="{{prod.img_url}}" mode="aspectFill"></image>
                  <view class="pill-btn overlay" data-mid="{{item._id}}" data-index="{{pidx}}" bindtap="onOpenProduct">
                    <text>打开心意</text>
                  </view>
                </view>
              </view>
            </swiper-item>
          </swiper>
          <view class="light-actions" wx:if="{{!item.actionsHidden}}">
            <button class="light-btn orange" bindtap="onGoMarketFromCards" data-mid="{{item._id}}">
              去礼物甄选
            </button>
            <button class="light-btn gray" bindtap="onDislikeProducts" data-mid="{{item._id}}">
              不感兴趣
            </button>
            <button class="light-btn outline" bindtap="onAnotherBatch" data-mid="{{item._id}}">
              换一批
            </button>
          </view>
          <view id="prod-anchor-{{item._id}}" class="end-anchor"></view>
        </block>
        <block wx:else>
          <view id="msg-{{index}}" class="bubble {{item.role === 'user' ? 'right' : 'left'}}">
            <block wx:if="{{item.typing}}">
              <view class="typing">
                <view class="dot"></view>
                <view class="dot"></view>
                <view class="dot"></view>
              </view>
            </block>
            <block wx:else>
              <text>{{item.content}}</text>
            </block>
          </view>
        </block>
      </block>
      <view id="end-anchor" class="end-anchor"></view>
    </view>
  </scroll-view>
  <view wx:if="{{!introMode}}" class="fixed-footer {{hasPills ? '' : 'no-pills'}}">
    <view class="footer-bg"></view>
    <view class="quick-actions">
      <text class="ai-tip">内容由AI技术生成</text>
      <view class="action-pill" bindtap="onNewChat">新聊天</view>
      <view class="action-pill" bindtap="onHistory">历史咨询</view>
      <view class="action-pill primary" bindtap="onQuickRecommend">立即推荐</view>
    </view>
    <scroll-view wx:if="{{hasPills}}" class="history-scroll" scroll-x="true" show-scrollbar="false">
      <view class="secondary-actions history-pills">
        <view class="pill lite">
          <text class="pill-text lite">上次送给妈妈的礼物</text>
        </view>
        <view class="pill lite">
          <text class="pill-text lite">给客户的感谢表达</text>
        </view>
        <view class="pill lite">
          <text class="pill-text lite">道歉礼物方案</text>
        </view>
        <view class="pill lite" bindtap="onGiftHistory">
          <text class="pill-text lite">礼赠历史</text>
        </view>
      </view>
    </scroll-view>
    <view class="input-area">
      <view class="input-box">
        <block wx:if="{{!voiceMode}}">
          <input class="input" placeholder="有问题，尽管问。" placeholder-style="color:#b3b3b3" value="{{inputValue}}" bindinput="onInput" confirm-type="send" bindconfirm="onSend" />
        </block>
        <block wx:else>
          <view class="voice-input {{recording ? 'recording' : ''}}" bindtouchstart="onVoiceStart" bindtouchend="onVoiceEnd" bindtouchcancel="onVoiceCancel">
            <text class="voice-text">{{voiceHint}}</text>
          </view>
        </block>
        <view class="voice-btn" bindtap="onToggleVoiceMode">
          <image class="voice-img" src="{{voiceMode ? '../../images/text.png' : '../../images/voice.png'}}" mode="aspectFit"></image>
        </view>
      </view>
      <view class="send-btn circle outside" bindtap="onSend">
        <image class="send-img" src="../../images/send.png" mode="aspectFit"></image>
      </view>
    </view>
  </view>
</view>