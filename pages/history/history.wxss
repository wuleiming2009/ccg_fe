.history-page {
  min-height: 100vh;
  background: #FEFAF8;
  padding: 40rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 120rpx 48rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: #F5EDE8;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #3D3D3D;
}

.empty-desc {
  font-size: 28rpx;
  color: #9B9B9B;
  text-align: center;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: #FFFFFF;
  border: 2rpx solid #F7E4D6;
  border-radius: 20rpx;
  padding: 20rpx 32rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.tags {
  display: flex;
  gap: 16rpx;
}

.tag {
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-orange { background: #FFE8DC; color: #E07B3C; }
.tag-green { background: #E3F2E8; color: #4CAF50; }
.tag-purple { background: #F3E8FF; color: #9C6ADE; }
.tag-blue { background: #E8F4FD; color: #4A9DE0; }
.tag-pink { background: #FFE4EF; color: #E05A9C; }
.tag-default { background: #F0F0F0; color: #888; }

.date {
  font-size: 20rpx;
  color: #B3B3B3;
}

.card-middle {
  margin-bottom: 20rpx;
}

.demand {
  font-size: 24rpx;
  font-weight: 400;
  color: #6D6158;
  line-height: 1.5;
}

.card-bottom {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.product {
  font-size: 20rpx;
  color: #B3B3B3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 480rpx;
  
}

.price {
  font-size: 20rpx;
  font-weight: 400;
  color: #B3B3B3;
}

.status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: auto;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.status-icon {
  font-size: 16rpx;
}

.status-done {
  background: #E3F2E8;
  color: #4CAF50;
}

.status-pending {
  /* background: #FFF0E0; */
  color: #E07B3C;
}

.status-text {
  white-space: nowrap;
}