.history-page {
  min-height: 100vh;
  background: #FFF8F5;
  padding: 12px;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 60px 24px;
}

.empty-icon {
  width: 80px;
  height: 80px;
  border-radius: 16px;
  background: #F5EDE8;
}

.empty-title {
  font-size: 18px;
  font-weight: 600;
  color: #3D3D3D;
}

.empty-desc {
  font-size: 14px;
  color: #9B9B9B;
  text-align: center;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.card {
  background: #FFFFFF;
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0 4px 20px rgba(180, 140, 120, 0.08);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.tags {
  display: flex;
  gap: 8px;
}

.tag {
  padding: 4px 12px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 500;
}

.tag-orange { background: #FFE8DC; color: #E07B3C; }
.tag-green { background: #E3F2E8; color: #4CAF50; }
.tag-purple { background: #F3E8FF; color: #9C6ADE; }
.tag-blue { background: #E8F4FD; color: #4A9DE0; }
.tag-pink { background: #FFE4EF; color: #E05A9C; }
.tag-default { background: #F0F0F0; color: #888; }

.date {
  font-size: 12px;
  color: #B0B0B0;
}

.card-middle {
  margin-bottom: 16px;
}

.demand {
  font-size: 18px;
  font-weight: 700;
  color: #2D2D2D;
  line-height: 1.5;
}

.card-bottom {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.product {
  font-size: 13px;
  color: #7A7A7A;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 120px;
}

.price {
  font-size: 13px;
  font-weight: 600;
  color: #FF7A3F;
}

.status {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-left: auto;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 12px;
}

.status-icon {
  font-size: 10px;
}

.status-done {
  background: #E3F2E8;
  color: #4CAF50;
}

.status-pending {
  background: #FFF0E0;
  color: #E07B3C;
}

.status-text {
  white-space: nowrap;
}