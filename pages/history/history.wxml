<view class="history-page">
  <view class="header"></view>

  <block wx:if="{{empty}}">
    <view class="empty-state">
      <image class="empty-icon" src="" mode="aspectFit"></image>
      <text class="empty-title">暂无记录</text>
      <text class="empty-desc">和顾问聊聊，生成你的第一份礼物清单吧。</text>
    </view>
  </block>

  <block wx:else>
    <view class="card-list">
      <view class="card" wx:for="{{items}}" wx:key="match_id" bindtap="onViewResult" data-id="{{item.match_id}}">
        <view class="card-top">
          <view class="tags">
            <view class="tag tag-{{item.tag1Color}}">{{item.tag1}}</view>
            <view class="tag tag-{{item.tag2Color}}">{{item.tag2}}</view>
          </view>
          <text class="date">{{item.date}}</text>
        </view>
        <view class="card-middle">
          <text class="demand">「{{item.demand}}」</text>
        </view>
        <view class="card-bottom">
          <text class="product">{{item.product}}</text>
          <text class="price">¥{{item.price}}</text>
          <view class="status {{item.statusClass}}">
            <text class="status-icon">{{item.statusIcon}}</text>
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>