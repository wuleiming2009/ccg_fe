.product-page {
	min-height: 100vh;
	background: #fefaf8;
}
.hero {
	height: 800rpx;
	background: #f8f9fa;
}
.hero-swiper {
	width: 100%;
	height: 100%;
}
.photo {
	width: 100%;
	height: 100%;
}
.imgprev-mask {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background: rgba(0, 0, 0, 0.5);
	z-index: 998;
}
.imgprev {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	z-index: 999;
	display: flex;
	align-items: center;
	justify-content: center;
}
.imgprev-swiper {
	width: 100vw;
	height: 100vh;
}
.imgprev-image {
	width: 100%;
	height: 100%;
}
.imgprev-close {
	position: absolute;
	right: 32rpx;
	top: 32rpx;
	width: 64rpx;
	height: 64rpx;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.9);
	color: #1f2a37;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 36rpx;
	box-shadow: 0 4rpx 12rpx rgba(31, 42, 55, 0.25);
}
.panel {
	margin-top: 0rpx;
	border-top-left-radius: 32rpx;
	border-top-right-radius: 32rpx;
	background: #fefaf8;
	box-shadow: 0 -12rpx 24rpx rgba(31, 42, 55, 0.06);
	padding: 40rpx;
	padding-bottom: 80rpx;
	padding-top: 20rpx;
}
.meta {
	margin-bottom: 32rpx;
}
.title {
	font-size: 36rpx;
	font-weight: 600;
	color: #6d6158;
}
.title.big {
	font-size: 40rpx;
	font-weight: 700;
}
.keywords {
	display: block;
	margin-top: 20rpx;
	font-size: 20rpx;
	color: #999999;
}
.price-row {
	margin-top: 20rpx;
	display: flex;
	align-items: baseline;
	justify-content: space-between;
	gap: 24rpx;
}
.price-left {
	display: flex;
	align-items: baseline;
	gap: 16rpx;
}
.price {
	font-size: 46rpx;
	font-weight: 700;
	color: #6d6158;
}
.mkt-price {
	font-size: 26rpx;
	color: #999999;
	text-decoration: line-through;
	margin-right: 16rpx;
}
.likes-row {
	display: flex;
	align-items: center;
	gap: 12rpx;
}
.likes-heart {
	width: 28rpx;
	height: 28rpx;
	display: block;
}
.likes-text {
	color: #ff4032;
	font-size: 20rpx;
}
.story {
	margin-top: 32rpx;
}
.story-label {
	font-size: 24rpx;
	color: #999999;
	letter-spacing: 2rpx;
}
.story-box {
	margin-top: 16rpx;
	background: #f8f9fa;
	border-radius: 24rpx;
	padding: 24rpx;
}
.reason {
	margin-top: 32rpx;
	background: #fcf3ea;
	border: 2rpx solid #ff7a3f;
	border-radius: 24rpx;
	padding: 28rpx;
}
.reason-header {
	display: flex;
	align-items: center;
	gap: 16rpx;
	margin-bottom: 16rpx;
}
.reason-dot {
	width: 56rpx;
	height: 56rpx;
	background: #ecbb8e;
	border-radius: 50%;
}
.reason-title {
	font-size: 26rpx;
	color: #ff7a3f;
	font-weight: 400;
}
.reason-text {
	margin-top: 8rpx;
	font-size: 24rpx;
	color: #6d6158;
	line-height: 1.6;
}
.info-card {
	margin-top: 32rpx;
	background: #ffffff;
	border: 2rpx solid #f2e7e2;
	border-radius: 24rpx;
	padding: 28rpx;
}
.section-title {
	font-size: 24rpx;
	color: #999999;
	letter-spacing: 2rpx;
}
.info-row {
	margin-top: 16rpx;
	display: flex;
	gap: 24rpx;
	align-items: center;
}
.info-label {
	width: 96rpx;
	color: #b3b3b3;
	font-size: 26rpx;
	flex-shrink: 0;
}
.info-value {
	flex: 1;
	color: #6d6158;
	font-size: 24rpx;
}
.info-value .info-value-text {
  line-height: 1.5;
}
.chips-card {
	margin-top: 26rpx;
	background: #ffffff;
	border: 2rpx solid #b3b3b3;
	border-radius: 24rpx;
	padding: 28rpx;
}
.sec-h {
	display: flex;
	align-items: center;
	gap: 12rpx;
	margin-bottom: 20rpx;
}
.sec-bar {
	width: 8rpx;
	height: 24rpx;
	background: #ff7a3f;
	border-radius: 4rpx;
}
.sec-title {
	font-size: 24rpx;
	color: #ff7a3f;
	font-weight: 400;
}
.chips {
	display: flex;
	flex-wrap: wrap;
	gap: 12rpx 16rpx;
	margin-bottom: 20rpx;
}
.chip {
	padding: 10rpx 20rpx;
	border-radius: 999rpx;
	background: #f8f9fa;
	color: #666666;
	font-size: 24rpx;
	border: 1rpx solid #e6ecf3;
}
.chip.orange {
	background: #fcf3ea;
	color: #ff7a3f;
	border-color: #f2e7e2;
	border: none;
}
.story-text {
	font-size: 24rpx;
	color: #333333;
	line-height: 1.6;
}
.cta {
	margin-top: 40rpx;
	margin-bottom: 48rpx;
	width: 100%;
	min-width: 100%;
	height: 96rpx;
	background: #ff7a3f;
	color: #f4f5f7;
	border-radius: 48rpx;
	display: block;
	text-align: center;
	line-height: 96rpx;
	font-size: 28rpx;
	font-weight: 600;
	letter-spacing: 1rpx;
	white-space: nowrap;
	border: none;
	padding: 0;
	box-sizing: border-box;
	margin-left: 0;
	margin-right: 0;
}
.cta::after {
	border: none;
}
.gift-btn {
	margin-top: 32rpx;
	width: 100%;
	background: #000000;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 24rpx 36rpx;
	font-weight: 600;
	text-align: center;
}

.bottom-actions {
	margin-top: 32rpx;
	/* margin-bottom: 48rpx;  */
	display: flex;
	align-items: center;
	justify-content: flex-start;
	gap: 16rpx;
}
.like-box {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	width: 96rpx;
	flex: none;
}
.like-btn {
	width: 80rpx;
	height: 80rpx;
	border-radius: 50%;
	background: #ffffff;
	border: 1rpx solid #b3b3b3;
	display: flex;
	align-items: center;
	justify-content: center;
	box-shadow: 0 8rpx 20rpx rgba(31, 42, 55, 0.08);
}
.like-btn .like-heart {
	width: 47rpx;
	height: 47rpx;
	display: block;
}
.like-count {
	margin-top: 6rpx;
	font-size: 20rpx;
	color: #b3b3b3;
}
.cta.cta-mini {
	margin: 0;
	min-width: 0;
	flex: 1;
	height: 96rpx;
	line-height: 96rpx;
	border-radius: 48rpx;
	font-size: 28rpx;
	font-weight: 400;
	color: #f4f5f7;
}

.quantity {
	margin-top: 32rpx;
}
.quantity-label {
	font-size: 24rpx;
	color: #999999;
	letter-spacing: 1rpx;
}
.qty-controls {
	margin-top: 16rpx;
	display: flex;
	align-items: center;
	gap: 24rpx;
}
.qty-btn {
	width: 56rpx;
	height: 56rpx;
	border-radius: 50%;
	border: 1rpx solid #b3b3b3;
	color: #b3b3b3;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 24rpx;
}
.qty-count {
	font-size: 28rpx;
	color: #6d6158;
	font-weight: 600;
}

/* Bottom sheet */
.sheet-mask {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background: rgba(0, 0, 0, 0.25);
	backdrop-filter: blur(4rpx);
}
.sheet {
	position: fixed;
	left: 0;
	right: 0;
	bottom: 0;
	background: #ffffff;
	border-top-left-radius: 24rpx;
	border-top-right-radius: 24rpx;
	box-shadow: 0 -12rpx 32rpx rgba(31, 42, 55, 0.1);
	padding: 32rpx;
}
.sheet-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
}
.sheet-title {
	font-size: 28rpx;
	font-weight: 600;
	color: #333333;
}
.sheet-close {
	width: 48rpx;
	height: 48rpx;
	border-radius: 50%;
	background: #f8f9fa;
	color: #333333;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 24rpx;
}
.sheet-section {
	margin-top: 24rpx;
}
.sheet-row {
	display: flex;
	justify-content: space-between;
	align-items: center;
}
.sheet-label {
	font-size: 24rpx;
	color: #333333;
	font-weight: 600;
}
.sheet-action {
	font-size: 22rpx;
	color: #ff7a3f;
}
.sheet-hint {
	margin-top: 8rpx;
	font-size: 22rpx;
	color: #999999;
}
.sheet-address {
	margin-top: 16rpx;
	background: #f8f9fa;
	border: 1rpx solid #e6ecf3;
	border-radius: 16rpx;
	padding: 24rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 16rpx;
}
.sheet-address-empty {
	font-size: 24rpx;
	color: #999999;
}
.sheet-add-btn {
	background: #ff7a3f;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 12rpx 24rpx;
	font-size: 24rpx;
}
.sheet-divider {
	height: 1rpx;
	background: #e6ecf3;
	margin: 24rpx 0;
}
.sheet-item {
	font-size: 24rpx;
	color: #333333;
}
.sheet-price {
	font-size: 28rpx;
	font-weight: 700;
	color: #ff7a3f;
}
.sheet-primary {
	margin-top: 24rpx;
	width: 100%;
	background: #ff7a3f;
	color: #ffffff;
	border-radius: 48rpx;
	padding: 24rpx 36rpx;
	font-weight: 600;
	font-size: 26rpx;
}

/* recipients */
.rec-list {
	margin-top: 16rpx;
	height: 440rpx;
}
.rec-list swiper-item {
	display: flex;
	align-items: center;
}
/* swiper 使用，无需 rec-row */
.rec-card {
	width: 86%;
	min-height: 280rpx;
	background: #ffffff;
	border: 2rpx solid #e6ecf3;
	border-radius: 32rpx;
	padding: 40rpx;
	position: relative;
	box-shadow: 0 16rpx 40rpx rgba(31, 42, 55, 0.1);
	transform: scale(0.92);
	transform-origin: center;
	transition:
		transform 0.25s ease,
		box-shadow 0.25s ease;
	z-index: 1;
	margin: 0 auto;
}
.rec-card.selected {
	background: #ff7a3f;
	color: #ffffff;
}
.rec-card.selected {
	transform: scale(1);
	box-shadow: 0 24rpx 48rpx rgba(31, 42, 55, 0.16);
	z-index: 2;
}
.rec-top {
	display: flex;
	justify-content: space-between;
	align-items: center;
}
.rec-tag {
	font-size: 24rpx;
	color: #9aa4b2;
}
.rec-card.selected .rec-tag {
	color: rgba(255, 255, 255, 0.8);
}
.rec-actions {
	position: absolute;
	right: 24rpx;
	top: 24rpx;
	display: flex;
	flex-direction: column;
	gap: 12rpx;
}
.rec-edit,
.rec-del {
	width: 48rpx;
	height: 48rpx;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 28rpx;
	color: #9aa4b2;
	background: #ffffff;
	box-shadow: 0 4rpx 12rpx rgba(31, 42, 55, 0.12);
	border: 2rpx solid #e6ecf3;
}
.rec-card.selected .rec-edit,
.rec-card.selected .rec-del {
	color: #ffffff;
	background: rgba(255, 255, 255, 0.3);
	box-shadow: none;
	border-color: rgba(255, 255, 255, 0.5);
}
.rec-info {
	margin-top: 12rpx;
	display: flex;
	flex-direction: column;
	gap: 16rpx;
}
.rec-name {
	font-size: 40rpx;
	font-weight: 800;
	color: #1f2a37;
}
.rec-card.selected .rec-name {
	color: #ffffff;
}
.rec-phone {
	font-size: 32rpx;
	color: #4b5563;
	font-weight: 600;
}
.rec-card.selected .rec-phone {
	color: #ffffff;
}
.rec-addr {
	font-size: 28rpx;
	color: #9aa4b2;
}
.rec-card.selected .rec-addr {
	color: rgba(255, 255, 255, 0.85);
}
.rec-default {
	position: absolute;
	right: 24rpx;
	bottom: 24rpx;
	padding: 4rpx 16rpx;
	border-radius: 999rpx;
	border: 2rpx solid #ff7a3f;
	color: #ff7a3f;
	background: #fff7f2;
	font-size: 24rpx;
}
.rec-card.selected .rec-default {
	border-color: #ffffff;
	color: #ffffff;
	background: rgba(255, 255, 255, 0.24);
}
/* removed checkmark */

/* Recipient modal */
.modal-mask {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	background: rgba(0, 0, 0, 0.35);
	backdrop-filter: blur(4rpx);
	z-index: 999;
}
.modal {
	position: fixed;
	left: 24rpx;
	right: 24rpx;
	top: 20%;
	background: #ffffff;
	border-radius: 32rpx;
	box-shadow: 0 24rpx 48rpx rgba(31, 42, 55, 0.16);
	padding: 32rpx;
	z-index: 1000;
}
.modal-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
}
.modal-title {
	font-size: 36rpx;
	font-weight: 700;
	color: #1f2a37;
}
.modal-close {
	width: 56rpx;
	height: 56rpx;
	border-radius: 50%;
	background: #f4f6f8;
	color: #1f2a37;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 24rpx;
}
.modal-body {
	margin-top: 24rpx;
	display: flex;
	flex-direction: column;
	gap: 24rpx;
}
.modal-label {
	font-size: 24rpx;
	color: #9aa4b2;
}
.modal-input {
	border-bottom: 2rpx solid #e6ecf3;
	padding: 16rpx 8rpx;
	font-size: 28rpx;
}
.ph {
	font-size: 24rpx;
	color: #9aa4b2;
}
.smart-card {
	background: #ffffff;
	border: 2rpx solid #e6ecf3;
	border-radius: 24rpx;
	padding: 20rpx;
	box-shadow: 0 4rpx 16rpx rgba(31, 42, 55, 0.06);
}
.smart-textarea {
	width: 100%;
	min-height: 144rpx;
	background: #ffffff;
	border: 2rpx solid #e6ecf3;
	border-radius: 24rpx;
	padding: 20rpx 24rpx;
	box-sizing: border-box;
	color: #1f2a37;
	font-size: 28rpx;
}
.smart-row {
	margin-top: 16rpx;
	display: flex;
	justify-content: flex-start;
	align-items: center;
}
.sticky-btn {
	background: #ff7a3f;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 16rpx 28rpx;
	font-size: 24rpx;
}
.wx-address-btn {
	margin-top: 16rpx;
	width: auto;
	background: #07c160;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 12rpx 20rpx;
	font-weight: 600;
	font-size: 24rpx;
}
.modal-primary {
	margin-top: 24rpx;
	width: 100%;
	background: #ff7a3f;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 24rpx 36rpx;
	font-weight: 600;
	font-size: 28rpx;
}
.modal-secondary {
	margin-top: 24rpx;
	width: 100%;
	background: #f4f6f8;
	color: #1f2a37;
	border-radius: 999rpx;
	padding: 24rpx 36rpx;
	font-weight: 600;
	font-size: 28rpx;
}
.modal-actions {
	display: flex;
	gap: 20rpx;
}
.invite .modal-actions {
	margin-top: 24rpx;
}
.letter {
	position: relative;
	background: #ffffff;
	border: 2rpx solid #e6ecf3;
	border-radius: 32rpx;
	box-shadow: 0 8rpx 24rpx rgba(31, 42, 55, 0.08);
	overflow: hidden;
}
.letter-top {
	height: 80rpx;
	background: linear-gradient(180deg, #fff7f2 0%, #ffffff 100%);
	border-bottom: 2rpx solid #f2e7e2;
}
.letter-body {
	padding: 32rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 16rpx;
}
.letter-line {
	font-size: 28rpx;
	color: #7a8ca5;
}
.invite-name {
	font-size: 36rpx;
	font-weight: 700;
	color: #ff7a3f;
	padding: 12rpx 20rpx;
	border-radius: 16rpx;
	border: 2rpx dashed #ff7a3f;
}
.invite-input {
	width: 80%;
	border: 2rpx solid #e6ecf3;
	border-radius: 16rpx;
	padding: 16rpx 20rpx;
	font-size: 28rpx;
}

.wx-name-btn {
	margin-top: 16rpx;
	background: #07c160;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 12rpx 20rpx;
	width: auto;
	display: inline-block;
	font-size: 24rpx;
}
.wx-phone-btn {
	margin-top: 16rpx;
	background: #07c160;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 12rpx 20rpx;
	width: auto;
	display: inline-block;
	font-size: 24rpx;
}
.ask-row {
	display: flex;
	align-items: flex-end;
	justify-content: space-between;
	gap: 20rpx;
}
.modal-info {
	display: flex;
	flex-direction: column;
}
.wx-all-btn {
	margin-top: 16rpx;
	background: #07c160;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 20rpx 28rpx;
	width: 100%;
	display: inline-block;
	text-align: center;
	font-size: 28rpx;
}
.wx-all-btn.small {
	width: auto;
	padding: 12rpx 20rpx;
	font-size: 24rpx;
}
.modal-hint {
	margin-top: 12rpx;
	font-size: 28rpx;
	color: #4b5563;
}
.ask-field {
	margin-top: 12rpx;
	display: flex;
	align-items: center;
	gap: 16rpx;
}
.ask-label {
	font-size: 28rpx;
	color: #1f2a37;
	width: 112rpx;
}
.ask-input {
	flex: 1;
	height: 64rpx;
	background: #ffffff;
	border-radius: 999rpx;
	padding: 12rpx 20rpx;
	box-shadow: inset 0 0 0 2rpx #d8e2f0;
	color: #1f2a37;
	font-size: 28rpx;
	max-width: 480rpx;
}
.ask-value {
	flex: 1;
	min-height: 64rpx;
	display: flex;
	align-items: center;
	padding: 0 16rpx;
	color: #1f2a37;
	font-size: 28rpx;
}
.ask .modal-actions {
	margin-top: 36rpx;
}
.modal-field {
	display: flex;
	flex-direction: column;
	gap: 12rpx;
}
.modal-switch {
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
}
.switch-small {
	transform: scale(0.6);
	transform-origin: right center;
}
.detail {
	margin-top: 24rpx;
}
.detail-label {
	font-size: 24rpx;
	color: #9aa4b2;
	letter-spacing: 2rpx;
}
.detail-box {
	margin-top: 12rpx;
	background: #f7faff;
	border-radius: 24rpx;
	padding: 24rpx;
}
.detail-text {
	font-size: 28rpx;
	color: #1f2a37;
	line-height: 1.6;
}
.rec-card.invite {
	background: #ffffff;
	border-color: #e6ecf3;
	color: #1f2a37;
}
.rec-card.invite.selected {
	background: #ff7a3f;
	color: #ffffff;
}
.rec-card.invite .rec-tag {
	color: #9aa4b2;
	letter-spacing: 4rpx;
}
.rec-card.invite .rec-info .big {
	font-size: 40rpx;
	font-weight: 800;
	color: #1f2a37;
}
.rec-card.invite .rec-info .tip {
	font-size: 28rpx;
	color: #9aa4b2;
	margin-top: 8rpx;
}
.rec-card.invite.selected .rec-tag {
	color: rgba(255, 255, 255, 0.85);
}
.rec-card.invite.selected .rec-info .big {
	color: #ffffff;
}
.rec-card.invite.selected .rec-info .tip {
	color: rgba(255, 255, 255, 0.85);
}
.rec-card.invite .rec-send {
	width: auto;
	height: auto;
}
.rec-send {
	margin-top: 20rpx;
	align-self: flex-start;
	background: #ff7a3f;
	color: #ffffff;
	border-radius: 999rpx;
	padding: 12rpx 20rpx;
	font-size: 24rpx;
	display: inline-block;
	white-space: nowrap;
}
