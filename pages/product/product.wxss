.product-page { min-height: 100vh; background: #fefaf9; }
.hero { height: 400px; background: #EAF0F5; }
.hero-swiper { width: 100%; height: 100%; }
.photo { width: 100%; height: 100%; }
.imgprev-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 998; }
.imgprev { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 999; display: flex; align-items: center; justify-content: center; }
.imgprev-swiper { width: 100vw; height: 100vh; }
.imgprev-image { width: 100%; height: 100%; }
.imgprev-close { position: absolute; right: 16px; top: 16px; width: 32px; height: 32px; border-radius: 50%; background: rgba(255,255,255,0.9); color: #1F2A37; display: flex; align-items: center; justify-content: center; font-size: 18px; box-shadow: 0 2px 6px rgba(31,42,55,0.25); }
.panel { margin-top: 4px; border-top-left-radius: 16px; border-top-right-radius: 16px; background: #FFFFFF; box-shadow: 0 -6px 12px rgba(31,42,55,0.06); padding: 16px; padding-bottom: 36px; }
.meta { margin-bottom: 12px; }
.title { font-size: 20px; font-weight: 700; color: #1F2A37; }
.title.big { font-size: 22px; }
.keywords { display: block; margin-top: 6px; font-size: 12px; color: #9AA4B2; }
.price-row { margin-top: 8px; display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
.price-left { display: flex; align-items: baseline; gap: 6px; }
.price { font-size: 20px; font-weight: 700; color: #1F2A37; }
.mkt-price { font-size: 14px; color: #9AA4B2; text-decoration: line-through; margin-right: 6px; }
.likes-row { display: flex; align-items: center; gap: 6px; }
.likes-heart { color: #FF4D4F; font-size: 14px; line-height: 1; }
.likes-text { color: #FF4D4F; font-size: 12px; }
.story { margin-top: 12px; }
.story-label { font-size: 12px; color: #9AA4B2; letter-spacing: 1px; }
.story-box { margin-top: 8px; background: #F7FAFF; border-radius: 12px; padding: 12px; }
.reason { margin-top: 12px; background: #FFF3E8; border: 1px solid #F2E7E2; border-radius: 12px; padding: 12px; }
.reason-header { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.reason-dot { width: 16px; height: 16px; border-radius: 8px; background: #ff7a3f; opacity: 0.8; }
.reason-title { font-size: 14px; color: #7A4B3A; font-weight: 700; }
.reason-text { margin-top: 2px; font-size: 14px; color: #1F2A37; line-height: 1.6; }
.info-card { margin-top: 12px; background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 16px; padding: 12px; }
.section-title { font-size: 12px; color: #9AA4B2; letter-spacing: 1px; } 
.info-row { margin-top: 6px; display: flex; gap: 10px; }
.info-label { width: 48px; color: #9AA4B2; font-size: 14px; }
.info-value { flex: 1; color: #1F2A37; font-size: 14px; }
.chips-card { margin-top: 12px; background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 16px; padding: 12px; }
.sec-h { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
.sec-bar { width: 4px; height: 14px; background: #ff7a3f; border-radius: 4px; }
.sec-title { font-size: 14px; color: #7A4B3A; font-weight: 700; }
.chips { display: flex; flex-wrap: wrap; gap: 8px 10px; }
.chip { padding: 6px 12px; border-radius: 999px; background: #F4F6F8; color: #666; font-size: 12px; border: 1px solid #E6ECF3; }
.chip.orange { background: #FFF3E8; color: #ff7a3f; border-color: #F2E7E2; }
.story-text { font-size: 14px; color: #1F2A37; line-height: 1.6; }
.cta { margin-top: 16px; margin-bottom: 24px; width: 100%; min-width: 100%; height: 52px; background: #ff7a3f; color: #FFFFFF; border-radius: 26px; display: block; text-align: center; line-height: 52px; font-size: 16px; font-weight: 600; letter-spacing: 1px; white-space: nowrap; border: none; padding: 0; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.cta::after { border: none; }
.gift-btn { margin-top: 16px; width: 100%; background: #000000; color: #FFFFFF; border-radius: 999px; padding: 12px 18px; font-weight: 600; text-align: center; }

.bottom-actions { margin-top: 14px; margin-bottom: 24px; display: flex; align-items: center; justify-content: flex-start; gap: 6px; }
.like-box { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 52px; flex: none; }
.like-btn { width: 40px; height: 40px; border-radius: 20px; background: #FFFFFF; border: 1px solid #E6ECF3; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 14px rgba(31,42,55,0.10); }
.like-heart { font-size: 18px; line-height: 1; }
.like-btn.unliked .like-heart { color: #B9C2CF; }
.like-btn.liked .like-heart { color: #FF4D4F; }
.like-count { margin-top: 6px; font-size: 12px; color: #9AA4B2; }
.cta.cta-mini { margin: 0; min-width: 0; flex: 1; height: 54px; line-height: 54px; border-radius: 27px; }

.quantity { margin-top: 12px; }
.quantity-label { font-size: 12px; color: #9AA4B2; letter-spacing: 1px; }
.qty-controls { margin-top: 8px; display: flex; align-items: center; gap: 12px; }
.qty-btn { width: 32px; height: 32px; border-radius: 50%; border: 1px solid #E3E8EF; color: #7A8CA5; display: flex; align-items: center; justify-content: center; }
.qty-count { font-size: 16px; color: #1F2A37; font-weight: 600; }

/* Bottom sheet */
.sheet-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.25); backdrop-filter: blur(2px); }
.sheet { position: fixed; left: 0; right: 0; bottom: 0; background: #FFFFFF; border-top-left-radius: 16px; border-top-right-radius: 16px; box-shadow: 0 -8px 20px rgba(31,42,55,0.12); padding: 16px; }
.sheet-header { display: flex; justify-content: space-between; align-items: center; }
.sheet-title { font-size: 18px; font-weight: 700; color: #1F2A37; }
.sheet-close { width: 28px; height: 28px; border-radius: 50%; background: #F4F6F8; color: #1F2A37; display: flex; align-items: center; justify-content: center; }
.sheet-section { margin-top: 12px; }
.sheet-row { display: flex; justify-content: space-between; align-items: center; }
.sheet-label { font-size: 14px; color: #1F2A37; font-weight: 600; }
.sheet-action { font-size: 13px; color: #1F2A37; }
.sheet-hint { margin-top: 4px; font-size: 12px; color: #9AA4B2; }
.sheet-address { margin-top: 8px; background: #F7FAFF; border: 1px solid #E6ECF3; border-radius: 12px; padding: 16px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
.sheet-address-empty { font-size: 13px; color: #7A8CA5; }
.sheet-add-btn { background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 8px 16px; font-size: 14px; }
.sheet-divider { height: 1px; background: #E6ECF3; margin: 12px 0; }
.sheet-item { font-size: 14px; color: #1F2A37; }
.sheet-price { font-size: 16px; font-weight: 700; color: #1F2A37; }
.sheet-primary { margin-top: 12px; width: 100%; background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 12px 18px; font-weight: 600; }

/* recipients */
.rec-list { margin-top: 8px; height: 220px; }
.rec-list swiper-item { display: flex; align-items: center; }
/* swiper 使用，无需 rec-row */
.rec-card { width: 86%; min-height: 140px; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 16px; padding: 20px; position: relative; box-shadow: 0 8px 20px rgba(31,42,55,0.10); transform: scale(0.92); transform-origin: center; transition: transform .25s ease, box-shadow .25s ease; z-index: 1; margin: 0 auto; }
.rec-card.selected { background: #ff7a3f; color: #FFFFFF; }
.rec-card.selected { transform: scale(1); box-shadow: 0 12px 24px rgba(31,42,55,0.16); z-index: 2; }
.rec-top { display: flex; justify-content: space-between; align-items: center; }
.rec-tag { font-size: 12px; color: #9AA4B2; }
.rec-card.selected .rec-tag { color: rgba(255,255,255,0.8); }
.rec-actions { position: absolute; right: 12px; top: 12px; display: flex; flex-direction: column; gap: 6px; }
.rec-edit, .rec-del { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #9AA4B2; background: #FFFFFF; box-shadow: 0 2px 6px rgba(31,42,55,0.12); border: 1px solid #E6ECF3; }
.rec-card.selected .rec-edit, .rec-card.selected .rec-del { color: #FFFFFF; background: rgba(255,255,255,0.30); box-shadow: none; border-color: rgba(255,255,255,0.50); }
.rec-info { margin-top: 6px; display: flex; flex-direction: column; gap: 8px; }
.rec-name { font-size: 20px; font-weight: 800; color: #1F2A37; }
.rec-card.selected .rec-name { color: #FFFFFF; }
.rec-phone { font-size: 16px; color: #4B5563; font-weight: 600; }
.rec-card.selected .rec-phone { color: #FFFFFF; }
.rec-addr { font-size: 14px; color: #9AA4B2; }
.rec-card.selected .rec-addr { color: rgba(255,255,255,0.85); }
.rec-default { position: absolute; right: 12px; bottom: 12px; padding: 2px 8px; border-radius: 999px; border: 1px solid #ff7a3f; color: #ff7a3f; background: #FFF7F2; font-size: 12px; }
.rec-card.selected .rec-default { border-color: #FFFFFF; color: #FFFFFF; background: rgba(255,255,255,0.24); }
/* removed checkmark */

/* Recipient modal */
.modal-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.35); backdrop-filter: blur(2px); z-index: 999; }
.modal { position: fixed; left: 12px; right: 12px; top: 20%; background: #FFFFFF; border-radius: 16px; box-shadow: 0 12px 24px rgba(31,42,55,0.16); padding: 16px; z-index: 1000; }
.modal-header { display: flex; justify-content: space-between; align-items: center; }
.modal-title { font-size: 18px; font-weight: 700; color: #1F2A37; }
.modal-close { width: 28px; height: 28px; border-radius: 50%; background: #F4F6F8; color: #1F2A37; display: flex; align-items: center; justify-content: center; }
.modal-body { margin-top: 12px; display: flex; flex-direction: column; gap: 12px; }
.modal-label { font-size: 12px; color: #9AA4B2; }
.modal-input { border-bottom: 1px solid #E6ECF3; padding: 8px 4px; }
.ph { font-size: 12px; color: #9AA4B2; }
.smart-card { background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 12px; padding: 10px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); }
.smart-textarea { width: 100%; min-height: 72px; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 12px; padding: 10px 12px; box-sizing: border-box; color: #1F2A37; font-size: 14px; }
.smart-row { margin-top: 8px; display: flex; justify-content: flex-start; align-items: center; }
.sticky-btn { background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 8px 14px; font-size: 12px; }
.wx-address-btn { margin-top: 8px; width: auto; background: #07C160; color: #FFFFFF; border-radius: 999px; padding: 6px 10px; font-weight: 600; font-size: 12px; }
.modal-primary { margin-top: 12px; width: 100%; background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 12px 18px; font-weight: 600; }
.modal-secondary { margin-top: 12px; width: 100%; background: #F4F6F8; color: #1F2A37; border-radius: 999px; padding: 12px 18px; font-weight: 600; }
.modal-actions { display: flex; gap: 10px; }
.invite .modal-actions { margin-top: 12px; }
.letter { position: relative; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 16px; box-shadow: 0 4px 12px rgba(31,42,55,0.08); overflow: hidden; }
.letter-top { height: 40px; background: linear-gradient(180deg, #FFF7F2 0%, #FFFFFF 100%); border-bottom: 1px solid #F2E7E2; }
.letter-body { padding: 16px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
.letter-line { font-size: 14px; color: #7A8CA5; }
.invite-name { font-size: 18px; font-weight: 700; color: #ff7a3f; padding: 6px 10px; border-radius: 8px; border: 1px dashed #ff7a3f; }
.invite-input { width: 80%; border: 1px solid #E6ECF3; border-radius: 8px; padding: 8px 10px; }

.wx-name-btn { margin-top: 8px; background: #07C160; color: #FFFFFF; border-radius: 999px; padding: 6px 10px; width: auto; display: inline-block; }
.wx-phone-btn { margin-top: 8px; background: #07C160; color: #FFFFFF; border-radius: 999px; padding: 6px 10px; width: auto; display: inline-block; }
.ask-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 10px; }
.modal-info { display: flex; flex-direction: column; }
.wx-all-btn { margin-top: 8px; background: #07C160; color: #FFFFFF; border-radius: 999px; padding: 10px 14px; width: 100%; display: inline-block; text-align: center; }
.wx-all-btn.small { width: auto; padding: 6px 10px; font-size: 12px; }
.modal-hint { margin-top: 6px; font-size: 14px; color: #4B5563; }
.ask-field { margin-top: 6px; display: flex; align-items: center; gap: 8px; }
.ask-label { font-size: 14px; color: #1F2A37; width: 56px; }
.ask-input { flex: 1; height: 32px; background: #FFFFFF; border-radius: 999px; padding: 6px 10px; box-shadow: inset 0 0 0 1px #D8E2F0; color: #1F2A37; font-size: 14px; max-width: 240px; }
.ask-value { flex: 1; min-height: 32px; display: flex; align-items: center; padding: 0 8px; color: #1F2A37; font-size: 14px; }
.ask .modal-actions { margin-top: 18px; }
.modal-field { display: flex; flex-direction: column; gap: 6px; }
.modal-switch { flex-direction: row; justify-content: space-between; align-items: center; }
.switch-small { transform: scale(0.6); transform-origin: right center; }
.detail { margin-top: 12px; }
.detail-label { font-size: 12px; color: #9AA4B2; letter-spacing: 1px; }
.detail-box { margin-top: 6px; background: #F7FAFF; border-radius: 12px; padding: 12px; }
.detail-text { font-size: 14px; color: #1F2A37; line-height: 1.6; }
.rec-card.invite { background: #FFFFFF; border-color: #E6ECF3; color: #1F2A37; }
.rec-card.invite.selected { background: #ff7a3f; color: #FFFFFF; }
.rec-card.invite .rec-tag { color: #9AA4B2; letter-spacing: 2px; }
.rec-card.invite .rec-info .big { font-size: 20px; font-weight: 800; color: #1F2A37; }
.rec-card.invite .rec-info .tip { font-size: 14px; color: #9AA4B2; margin-top: 4px; }
.rec-card.invite.selected .rec-tag { color: rgba(255,255,255,0.85); }
.rec-card.invite.selected .rec-info .big { color: #FFFFFF; }
.rec-card.invite.selected .rec-info .tip { color: rgba(255,255,255,0.85); }
.rec-card.invite .rec-send { width: auto; height: auto; }
.rec-send { margin-top: 10px; align-self: flex-start; background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 6px 10px; font-size: 12px; display: inline-block; white-space: nowrap; }
