.guide { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: #fefaf9; display: flex; flex-direction: column; }
.guide-swiper { flex: 1; width: 100%; height: 100%; }
.slide { width: 100%; height: auto; display: block; }
.controls { position: absolute; left: 0; right: 0; bottom: 64px; display: flex; flex-direction: column; align-items: center; }
.dots { display: flex; gap: 8px; margin-bottom: 12px; }
.dot { width: 6px; height: 6px; border-radius: 6px; background: rgba(31,42,55,0.2); }
.dot.active { width: 18px; background: #FF7A3F; transition: all .2s; }
.btn-row { width: 84%; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
.btn-row.single { justify-content: center; }
.btn { flex: 1; padding: 12px 16px; border-radius: 999px; font-size: 16px; }
.btn.primary { background: #FF7A3F; color: #fff; border: none; }
.btn.ghost { background: #fff; color: #1F2A37; border: 1px solid rgba(31,42,55,0.15); }
.spacer { flex: 1; height: 44px; }
.btn.long { width: 100%; }
.skip { margin-top: 10px; font-size: 12px; color: rgba(31,42,55,0.45); }

.custom-nav { position: fixed; left: 0; right: 0; top: 0; z-index: 20; }
.custom-nav .nav-bg { position: absolute; left: 0; right: 0; top: 0; bottom: 0; width: 100%; height: 100%; }
.custom-nav .nav-content { position: relative; height: 44px; display: flex; align-items: center; justify-content: center; }
.custom-nav .nav-title { color: #1F2A37; font-size: 16px; }
