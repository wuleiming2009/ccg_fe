.guide { position: fixed; left: 0; right: 0; top: 0; bottom: 0; display: flex; flex-direction: column; }
.guide-swiper { flex: 1; width: 100%; height: 100%; }
.slide { width: 100%; height: auto; display: block; }
.controls { position: absolute; left: 0; right: 0; bottom: 128rpx; display: flex; flex-direction: column; align-items: center; }
.dots { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.dot { width: 12rpx; height: 12rpx; border-radius: 12rpx; background: rgba(31,42,55,0.2); }
.dot.active { width: 36rpx; background: #FF7A3F; transition: all .2s; }
.btn-row { width: 84%; display: flex; align-items: center; justify-content: space-between; gap: 32rpx; }
.btn-row.single { justify-content: center; }
.btn { flex: 1; padding: 24rpx 32rpx; border-radius: 999px; font-size: 32rpx; }
.btn.primary { background: #FF7A3F; color: #fff; border: none; }
.btn.ghost { background: #fff; color: #1F2A37; border: 2rpx solid rgba(31,42,55,0.15); }
.spacer { flex: 1; height: 88rpx; }
.btn.long { width: 100%; }
.skip { margin-top: 20rpx; font-size: 24rpx; color: rgba(31,42,55,0.45); }

.custom-nav { position: fixed; left: 0; right: 0; top: 0; z-index: 20; }
.custom-nav .nav-bg { position: absolute; left: 0; right: 0; top: 0; bottom: 0; width: 100%; height: 100%; }
.custom-nav .nav-content { position: relative; height: 88rpx; display: flex; align-items: center; justify-content: center; }
.custom-nav .nav-title { color: #1F2A37; font-size: 32rpx; }
