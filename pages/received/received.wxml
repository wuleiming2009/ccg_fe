<view class="received-page">
  <view class="tabs">
    <block wx:for="{{tabs}}" wx:key="tab">
      <view class="tab {{activeTab === item ? 'active' : ''}}" bindtap="onTabChange" data-tab="{{item}}">{{item}}</view>
    </block>
  </view>
  <view class="list">
    <block wx:if="{{orders.length > 0}}">
      <block wx:for="{{orders}}" wx:key="order_id">
        <view class="card order-card" bindtap="onOpenOrder" data-id="{{item.order_id}}">
          <view class="order-header">
            <text class="order-code">订单号 {{item.order_id}}</text>
            <text class="order-status">{{item.order_status_text}}</text>
          </view>
          <view class="dash-divider"></view>
          <view class="order-body">
            <image class="thumb" src="{{item.img_url}}" mode="aspectFill"></image>
            <view class="meta">
              <text class="title">{{item.name}}</text>
              <view class="row">
                <text class="label">送礼人</text>
                <text class="value">{{item.send_user_name || '—'}}</text>
              </view>
              <view class="dash-divider"></view>
              <view class="row">
                <text class="label">创建时间</text>
                <text class="value">{{item.create_time}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </block>
    <block wx:else>
      <view class="empty">暂无收到的礼物</view>
    </block>
  </view>
</view>
