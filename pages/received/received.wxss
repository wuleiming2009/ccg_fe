.received-page { padding: 12px; }
.tabs { display: flex; gap: 16px; padding: 8px 4px; border-bottom: 1px solid #F2E7E2; }
.tab { font-size: 14px; color: #9AA4B2; padding-bottom: 6px; }
.tab.active { color: #7A4B3A; border-bottom: 2px solid #ff7a3f; }
.toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.title { font-size: 18px; font-weight: 800; color: #1F2A37; }
.list { display: flex; flex-direction: column; gap: 10px; }
.card { background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 16px; padding: 12px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); }
.order-card {}
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.order-code { font-size: 12px; color: #9AA4B2; }
.order-status { font-size: 12px; color: #7A4B3A; }
.order-body { display: flex; gap: 10px; align-items: center; }
.thumb { width: 64px; height: 64px; border-radius: 8px; background: #E5E7EB; }
.meta { flex: 1; display: flex; flex-direction: column; gap: 6px; }
.row { display: flex; justify-content: space-between; align-items: baseline; }
.title { font-size: 16px; font-weight: 700; color: #1F2A37; }
.label { font-size: 12px; color: #9AA4B2; }
.value { font-size: 14px; color: #1F2A37; }
.empty { text-align: center; color: #9AA4B2; padding: 24px 0; }
.load-more { text-align: center; color: #1F2A37; background: #F4F6F8; padding: 8px 12px; border-radius: 999px; }
.dash-divider { height: 1px; border-top: 1px dashed #E6ECF3; margin: 6px 0; }
