page, .confirm-page { background: #fefaf9; min-height: 100vh; padding-bottom: 24px; }
.confirm-page.self-mode { min-height: 115vh; }
.section { margin: 12px 12px; }
.card { background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 16px; padding: 12px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); }
.gift-card { height: 132px; box-sizing: border-box; }
.info-card { height: auto; min-height: 300px; box-sizing: border-box; }
.info-card.self { min-height: 360px; }
.bill-card { height: 210px; box-sizing: border-box; }
.sec-h { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
.sec-bar { width: 4px; height: 14px; background: #ff7a3f; border-radius: 4px; }
.sec-title { font-size: 14px; color: #7A4B3A; font-weight: 700; }
.gift-row { display: flex; gap: 12px; align-items: center; }
.thumb { width: 64px; height: 64px; border-radius: 8px; background: #F4F6F8; }
.gift-info { display: flex; flex-direction: column; gap: 4px; }
.g-name { font-size: 16px; font-weight: 700; color: #1F2A37; }
.g-sub { display: none; }
.g-price { font-size: 16px; font-weight: 700; color: #ff7a3f; }
.methods { display: flex; gap: 5px; justify-content: space-between; }
.method { width: 190px; height: 130px; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 16px; padding: 12px; box-sizing: border-box; display: flex; flex-direction: column; gap: 6px; justify-content: center; }
.method.selected { background: #EFE6FF; border-color: #CFB9FF; }
.method.recipient { }
.m-title { font-size: 14px; color: #7A4B3A; font-weight: 700; text-align: center; }
.m-sub { font-size: 14px; color: #A0A7B1; text-align: center; }
.method .pin { width: 10px; height: 10px; border-radius: 50%; background: #ff4d4f; margin: 0 auto 4px; box-shadow: 0 2px 0 rgba(255,77,79,0.3); }
.lock-ico { position: relative; width: 20px; height: 18px; margin: 0 auto 4px; }
.lock-top { position: absolute; left: 50%; top: -6px; width: 12px; height: 8px; border: 2px solid #7A8CA5; border-bottom: none; border-radius: 8px 8px 0 0; transform: translateX(-50%); background: transparent; }
.lock-body { width: 20px; height: 12px; background: #FFC04D; border: 1px solid #D9A73F; border-radius: 3px; display: flex; align-items: flex-start; justify-content: center; }
.keyhole { width: 4px; height: 6px; background: #7A4B3A; border-radius: 2px; margin-top: 3px; }
.privacy { margin-top: 8px; position: relative; padding-left: 22px; }
.lock { position: absolute; left: 20px; top: 0px; font-size: 16px; color: #ff7a3f; line-height: 1; }
.p-texts { display: flex; flex-direction: column; gap: 4px; width: 320px; }
.p-title { font-size: 14px; color: #7A4B3A; font-weight: 700; margin-left: 24px; }
.p-desc { font-size: 12px; color: #6B6460; line-height: 1.6; word-break: break-word; width: 320px; }
.addr-tools { display: flex; justify-content: flex-end; align-items: center; }
.addr-book { font-size: 12px; color: #07C160; }
.smart-card { margin-top: 8px; background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 12px; padding: 10px; }
.smart-textarea { width: 100%; min-height: 72px; background: #FFF5EE; border: 1px solid #F2E7E2; border-radius: 12px; padding: 10px 12px; box-sizing: border-box; color: #1F2A37; font-size: 14px; }
.sticky-btn { margin-top: 8px; background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 8px 14px; font-size: 12px; width: auto; display: block; margin-left: auto; margin-right: auto; }
.ph { font-size: 12px; color: #9AA4B2; }
.field { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; }
.label { font-size: 12px; color: #9AA4B2; }
.input { background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 12px; padding: 10px 12px; }
.bill { display: flex; flex-direction: column; gap: 8px; }
.row { display: flex; justify-content: space-between; align-items: center; }
.b-label { font-size: 14px; color: #6B6460; }
.b-val { font-size: 14px; color: #1F2A37; }
.b-val.green { color: #07C160; }
.strong { font-weight: 700; }
.divider { height: 1px; background: #F2E7E2; margin: 6px 0; }
.agreements { margin: 10px 12px 0; font-size: 12px; color: #9AA4B2; text-align: center; }
.footer-divider { height: 2px; margin: 20px 12px 20px; background: #F2E7E2; }
.footer { margin: 0 12px 20px; }
.confirm-page.self-mode .footer { margin: 0 12px 16px; }
.cta { width: 100% !important; min-width: 100%; height: 52px; background: #ff7a3f; color: #FFFFFF; border-radius: 26px; display: block; text-align: center; line-height: 52px; font-size: 16px; font-weight: 700; letter-spacing: 1px; border: none; padding: 0; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.cta::after { border: none; }
