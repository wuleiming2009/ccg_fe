.profile-page { background: #fefaf9; min-height: 100vh; position: relative; }
.content { height: 100vh; box-sizing: border-box; padding: 20px 16px 64px 16px; }
.avatar-box { display: flex; flex-direction: column; align-items: center; gap: 6px; margin-top: 8px; margin-bottom: 12px; }
.avatar-large { width: 96px; height: 96px; border-radius: 50%; background: #fff; box-shadow: 0 2px 12px rgba(31,42,55,0.10); }
.avatar-tip { font-size: 12px; color: #9AA4B2; }
.avatar-cancel { margin-top: 2px; font-size: 12px; color: #ff7a3f; }
.card { background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 16px; padding: 14px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); margin-bottom: 16px; }
.sec-h { display: flex; align-items: center; gap: 6px; margin-bottom: 12px; }
.sec-bar { width: 4px; height: 14px; background: #ff7a3f; border-radius: 4px; }
.sec-title { font-size: 12px; color: #9AA4B2; letter-spacing: 1px; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
.label { font-size: 14px; color: #7A4B3A; }
.input { width: 100%; box-sizing: border-box; height: 36px; background: #F7F7F7; border: 1px solid #F2E7E2; border-radius: 10px; padding: 8px 12px; font-size: 14px; color: #1F2A37; }
.picker { width: 100%; box-sizing: border-box; height: 36px; display: flex; align-items: center; padding: 0 12px; background: #F7F7F7; border: 1px solid #F2E7E2; border-radius: 10px; color: #1F2A37; }
.gender-row { display: flex; align-items: center; gap: 8px; }
.pill { padding: 6px 12px; border-radius: 999px; border: 1px solid #F2E7E2; background: #FFFFFF; color: #7A4B3A; font-size: 14px; }
.pill.active { background: #FFF3E8; border-color: #ff7a3f; color: #ff7a3f; }
.textarea { width: 100%; box-sizing: border-box; height: 48px; min-height: 48px; background: #F7F7F7; border: 1px solid #F2E7E2; border-radius: 10px; padding: 8px 12px; font-size: 14px; color: #1F2A37; }
.footer { padding: 12px 0 8px 0; }
.footer .save-btn { display: flex; align-items: center; justify-content: center; margin: 0 4px; width: auto; height: 52px; border-radius: 999px; background: #ff7a3f; color: #FFFFFF; font-weight: 700; }
