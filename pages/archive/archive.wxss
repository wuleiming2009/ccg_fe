.archive-page { background: #fefaf9; min-height: 100vh; padding: 24rpx; }
.tabs { display: flex; gap: 32rpx; padding: 16rpx 8rpx; border-bottom: 2rpx solid #F2E7E2; }
.tab { font-size: 28rpx; color: #9AA4B2; padding-bottom: 12rpx; }
.tab.active { color: #7A4B3A; border-bottom: 4rpx solid #ff7a3f; }
.list { margin-top: 24rpx; display: flex; flex-direction: column; gap: 24rpx; }
.card { background: #FFFFFF; border: 2rpx solid #E6ECF3; border-radius: 32rpx; padding: 28rpx; box-shadow: 0 8rpx 24rpx rgba(31,42,55,0.06); }
.card-header { display: flex; justify-content: space-between; align-items: center; }
.left { display: flex; align-items: baseline; gap: 16rpx; }
.name { font-size: 32rpx; font-weight: 700; color: #1F2A37; }
.count { font-size: 24rpx; color: #9AA4B2; }
.right { display: flex; align-items: center; gap: 20rpx; }
.phone { font-size: 24rpx; color: #9AA4B2; }
.chev { font-size: 32rpx; color: #9AA4B2; transform: rotate(0deg); transition: transform .2s ease; }
.chev.up { transform: rotate(180deg); }
.filter { margin-top: 24rpx; display: flex; align-items: center; gap: 16rpx; background: #F7FAFF; border-radius: 999rpx; padding: 20rpx 24rpx; }
.filter-icon { font-size: 24rpx; color: #9AA4B2; }
.filter-input { flex: 1; font-size: 28rpx; color: #4B5563; }
.order-card { background: #FFFFFF; border: 2rpx solid #F2E7E2; border-radius: 32rpx; padding: 24rpx; box-shadow: 0 4rpx 16rpx rgba(31,42,55,0.06); }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.order-code { font-size: 24rpx; color: #9AA4B2; }
.order-status { font-size: 24rpx; color: #7A4B3A; }
.order-body { display: flex; gap: 20rpx; align-items: center; }
.thumb { width: 128rpx; height: 128rpx; border-radius: 16rpx; background: #E5E7EB; }
.meta { flex: 1; display: flex; flex-direction: column; gap: 12rpx; }
.row { display: flex; justify-content: space-between; align-items: baseline; }
.title { font-size: 32rpx; font-weight: 700; color: #1F2A37; }
.tag { font-size: 24rpx; color: #9AA4B2; }
.label { font-size: 24rpx; color: #9AA4B2; }
.value { font-size: 28rpx; color: #1F2A37; }
.price { font-size: 32rpx; font-weight: 700; color: #1F2A37; }
.date { font-size: 24rpx; color: #9AA4B2; }
.dash-divider { height: 2rpx; border-top: 2rpx dashed #E6ECF3; margin: 12rpx 0; }
.load-more { margin-top: 20rpx; text-align: center; font-size: 24rpx; color: #4B5563; background: #FFFFFF; border: 2rpx solid #E6ECF3; border-radius: 999rpx; padding: 16rpx; }
.empty { margin-top: 24rpx; text-align: center; font-size: 26rpx; color: #9AA4B2; }
.orders-scroll { max-height: 480rpx; margin-top: 16rpx; }
