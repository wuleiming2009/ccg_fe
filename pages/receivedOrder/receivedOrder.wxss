.order-page { background: #fefaf9; min-height: 100vh; padding: 16px; }
.page-title { font-size: 16px; color: #7A4B3A; padding: 6px 0; }
.top-divider { height: 1px; background: #E6ECF3; margin: 10px 0 14px; }
.card { background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 16px; padding: 14px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); margin-bottom: 16px; }
.sec-h { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
.sec-bar { width: 4px; height: 14px; background: #ff7a3f; border-radius: 4px; }
.sec-title { font-size: 12px; color: #9AA4B2; letter-spacing: 1px; }
.rec-row { display: flex; flex-direction: column; gap: 6px; }
.rec-name { font-size: 20px; font-weight: 700; color: #7A4B3A; padding: 8px 0; }
.prod-row { display: flex; align-items: center; gap: 12px; position: relative; }
.prod-thumb { width: 96px; height: 96px; border-radius: 12px; background: #E5E7EB; }
.prod-meta { flex: 1; display: flex; flex-direction: column; gap: 8px; }
.prod-title { font-size: 16px; color: #1F2A37; }
.transport-row { display: flex; align-items: center; gap: 8px; }
.transport-text { font-size: 12px; color: #9AA4B2; }
.sep { color: #E6ECF3; }
.copy-link { font-size: 12px; color: #7A4B3A; text-decoration: underline; }
.status-tag { margin-top: 4px; font-size: 12px; color: #ff7a3f; background: #FFF3E8; border: 1px solid #F2E7E2; border-radius: 999px; padding: 2px 8px; display: inline-block; }
.status-tag.right { align-self: flex-end; }
.dash-divider { height: 1px; border-top: 1px dashed #E6ECF3; margin: 8px 0; }
.row { display: flex; justify-content: space-between; align-items: center; }
.label { font-size: 12px; color: #9AA4B2; }
.mono { font-family: monospace; font-size: 13px; color: #1F2A37; }
