.my-page { background: #fef3ef; min-height: 100vh; padding: 16px; }
.header-lite { display: flex; align-items: center; gap: 12px; }
.avatar { width: 88px; height: 88px; border-radius: 50%; background: #fff; box-shadow: 0 2px 8px rgba(31,42,55,0.06); }
.hi-wrap { display: flex; align-items: baseline; gap: 6px; }
.hi-text { font-size: 20px; color: #7A4B3A; }
.hi-arrow { font-size: 18px; color: #7A4B3A; }
.stats { margin-top: 14px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.stat-card { background: #fff; border: 1px solid #F2E7E2; border-radius: 16px; padding: 16px; text-align: center; box-shadow: 0 2px 8px rgba(31,42,55,0.06); }
.stat-num { font-size: 28px; color: #ff7a3f; font-weight: 700; }
.stat-label { margin-top: 6px; display: block; font-size: 12px; color: #9AA4B2; }
.section-title { margin: 18px 4px 10px; font-size: 14px; color: #7A4B3A; }
.service-list { display: flex; flex-direction: column; gap: 12px; }
.service-item { background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 16px; padding: 14px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); display: flex; align-items: center; justify-content: space-between; }
.svc-left { display: flex; flex-direction: column; gap: 6px; }
.svc-title { font-size: 16px; color: #1F2A37; }
.svc-sub { font-size: 12px; color: #9AA4B2; }
.svc-right { font-size: 16px; color: #7A4B3A; }

.modal-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.25); z-index: 999; }
.modal { position: fixed; left: 12px; right: 12px; top: 30%; background: #FFFFFF; border-radius: 16px; box-shadow: 0 12px 24px rgba(31,42,55,0.16); padding: 16px; z-index: 1000; }
.modal-title { font-size: 18px; font-weight: 700; color: #1F2A37; }
.modal-input { margin-top: 12px; height: 36px; background: #FFFFFF; border-radius: 999px; padding: 8px 12px; box-shadow: inset 0 0 0 1px #D8E2F0; color: #1F2A37; }
.modal-actions { margin-top: 12px; display: flex; gap: 8px; }
.modal-btn { flex: 1; border-radius: 999px; padding: 10px 14px; }
.modal-btn.light { background: #F4F6F8; color: #1F2A37; }
.modal-btn.dark { background: #ff7a3f; color: #FFFFFF; }
.qr-img { margin-top: 12px; width: 100%; height: 240px; border-radius: 12px; background: #FFFFFF; }
