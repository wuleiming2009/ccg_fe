<view class="my-page">
  <view class="header-lite" bindtap="onOpenSettings">
    <image class="avatar" src="{{avatar || 'https://wumuxuan-1253516064.cos.ap-shanghai.myqcloud.com/ccg/uni-app/default_head_img.png'}}" mode="aspectFill"></image>
    <view class="hi-wrap">
      <text class="hi-text">hi  {{name || '未命名'}}</text>
      <text class="hi-arrow">›</text>
    </view>
  </view>
  <view class="stats">
    <view class="stat-card" bindtap="onOpenArchive">
      <text class="stat-num">{{sentCount}}</text>
      <text class="stat-label">送出的心意</text>
    </view>
    <view class="stat-card" bindtap="onOpenReceived">
      <text class="stat-num">{{receivedCount}}</text>
      <text class="stat-label">收到的礼物</text>
    </view>
  </view>
  <view class="section-title">我的服务</view>
  <view class="service-list">
    <view class="service-item" bindtap="onOpenHistory">
      <view class="svc-left">
        <text class="svc-title">历史咨询记录</text>
        <text class="svc-sub">多次对话 · 接着聊</text>
      </view>
      <text class="svc-right">›</text>
    </view>
    <view class="service-item" bindtap="onOpenSettings">
      <view class="svc-left">
        <text class="svc-title">设置</text>
        <text class="svc-sub">通知 · 隐私 · 账号</text>
      </view>
      <text class="svc-right">›</text>
    </view>
    <view class="service-item" bindtap="onContact">
      <view class="svc-left">
        <text class="svc-title">联系我们</text>
        <text class="svc-sub">扫码添加 · 合作 / 咨询 / 定制</text>
      </view>
      <text class="svc-right">›</text>
    </view>
  </view>
  <view wx:if="{{showNameEdit}}" class="modal-mask" bindtap="onCloseModal"></view>
  <view wx:if="{{showNameEdit}}" class="modal">
    <text class="modal-title">修改名称</text>
    <input class="modal-input" value="{{name}}" bindinput="onNameInput" placeholder="请输入用户名" />
    <view class="modal-actions">
      <button class="modal-btn light" bindtap="onCloseModal">取消</button>
      <button class="modal-btn dark" bindtap="onSaveName">保存</button>
    </view>
  </view>
  <view wx:if="{{showContact}}" class="modal-mask" bindtap="onCloseContact"></view>
  <view wx:if="{{showContact}}" class="modal">
    <text class="modal-title">合作咨询</text>
    <image class="qr-img" src="{{contactQrUrl}}" mode="aspectFit" show-menu-by-longpress></image>
    <text class="qr-hint">长按识别二维码</text>
    <view class="modal-actions">
      <button class="modal-btn light" bindtap="onCloseContact">关闭</button>
    </view>
  </view>
</view>