page, .invite-page { background: #fefaf9; min-height: 100vh; }
.hero { padding: 32px 16px 18px; text-align: center; background: linear-gradient(180deg, #efe8ff 0%, #fefaf9 100%); }
.brand { font-size: 14px; letter-spacing: 3px; color: #9AA4B2; font-weight: 800; }
.brand .bang { color: #ff7a3f; }
.gift-wrap { margin: 10px auto 6px; width: 44px; height: 44px; border-radius: 22px; background: #FFFFFF; box-shadow: 0 4px 12px rgba(31,42,55,0.10); display: flex; align-items: center; justify-content: center; }
.gift-img { width: 28px; height: 28px; }
.main-title { margin-top: 6px; display: flex; flex-direction: column; gap: 6px; align-items: center; }
.main-title .main-cn { font-size: 22px; color: #6B6460; font-weight: 600; }
.sub-lines { display: flex; flex-direction: column; gap: 2px; align-items: center; }
.sub-lines text { font-size: 14px; color: #9AA4B2; }
.form { margin-top: 8px; padding: 12px 16px 48px; }
.field { margin-top: 12px; }
.label { font-size: 12px; color: #9AA4B2; letter-spacing: 1px; }
.input { margin-top: 6px; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 12px; padding: 12px 14px; }
.submit { margin-top: 16px; width: 100%; height: 52px; line-height: 52px; background: #ff7a3f; color: #FFFFFF; border-radius: 26px; display: block; text-align: center; font-size: 16px; font-weight: 600; letter-spacing: 1px; border: none; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.submit::after { border: none; }
.submit-hint { margin-top: 8px; width: 100%; text-align: center; font-size: 12px; color: #9AA4B2; display: block; }
.completed-card { margin: 12px 16px; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 16px; padding: 16px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); display: flex; flex-direction: column; align-items: center; gap: 8px; }
.completed-title { font-size: 18px; font-weight: 700; color: #1F2A37; }
.completed-note { font-size: 13px; color: #7A8CA5; }
.completed-btn { margin-top: 6px; background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 10px 16px; }
.ph { font-size: 12px; color: #9AA4B2; }
.smart-card { background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 16px; padding: 12px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); }
.smart-textarea { width: 100%; min-height: 72px; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 12px; padding: 10px 12px; box-sizing: border-box; color: #1F2A37; font-size: 14px; }
.smart-row { margin-top: 8px; display: flex; justify-content: flex-start; align-items: center; }
.sticky-btn { background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 8px 14px; font-size: 12px; align-self: flex-start; }
.addr-card { margin-top: 12px; background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 20px; padding: 14px 12px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); box-sizing: border-box; }
.addr-title-row { display: flex; align-items: center; margin-bottom: 6px; }
.addr-title-wrap { display: flex; align-items: center; gap: 6px; flex: 1; }
.addr-bar { width: 4px; height: 14px; border-radius: 4px; background: #ff7a3f; }
.addr-title { font-size: 14px; color: #7A4B3A; font-weight: 700; }
.addr-link { color: #07C160; font-size: 12px; padding: 4px 0; line-height: 1; margin-left: auto; }
.privacy-card { margin-top: 12px; background: #FFFFFF; border: 1px solid #F2E7E2; border-radius: 16px; padding: 12px; box-shadow: 0 2px 8px rgba(31,42,55,0.06); box-sizing: border-box; }
.privacy-header { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
.lock { font-size: 14px; color: #ff7a3f; }
.privacy-title { font-size: 14px; color: #7A4B3A; font-weight: 700; }
.privacy-text { font-size: 12px; color: #6B6460; line-height: 1.6; }
.privacy-text .em { color: #ff7a3f; font-weight: 700; }
.pill-group { display: flex; align-items: center; gap: 6px; background: #FFFFFF; border: 1px solid #E6ECF3; border-radius: 999px; padding: 6px 10px; }
.pill-item { color: #7A8CA5; font-size: 12px; }
.divider { color: #E3E8EF; }
.sticky-btn { background: #ff7a3f; color: #FFFFFF; border-radius: 999px; padding: 8px 14px; font-size: 12px; }
.wx-address-btn { margin-top: 12px; width: auto; background: #07C160; color: #FFFFFF; border-radius: 999px; padding: 6px 10px; font-weight: 600; font-size: 12px; align-self: flex-start; margin-left: 0; margin-right: auto; }
