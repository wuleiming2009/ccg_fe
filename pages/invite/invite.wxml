<view class="invite-page">
  <view class="hero">
    <text class="brand">CC G<text class="bang">!</text>FT</text>
    <view class="gift-wrap">
      <image class="gift-img" src="https://wumuxuan-1253516064.cos.ap-shanghai.myqcloud.com/ccg/uni-app/gift.png" mode="aspectFit"></image>
    </view>
    <view class="main-title">
      <text class="main-cn">{{sendUserNameDisplay}} 为您准备了一份礼物</text>
      <view class="sub-lines">
        <text>填写你的收货地址，</text>
        <text>礼物就会寄到你那里</text>
      </view>
    </view>
  </view>

  <view wx:if="{{completed}}" class="completed-card">
    <text class="completed-title">已填写礼赠地址</text>
    <text class="completed-note">感谢您已提交收货信息，礼物正在路上～</text>
    <button class="completed-btn" bindtap="onGoChat">去回礼</button>
  </view>

  <view wx:if="{{!completed}}" class="form">
    <view class="smart-card">
      <textarea class="smart-textarea" placeholder="「粘贴识别」或输入文本，智能拆分姓名、电话和地址" placeholder-class="ph" value="{{rawText}}" bindinput="onRawInput" auto-height="true" />
      <view class="smart-row">
        <button class="sticky-btn" bindtap="onPasteRecognize">粘贴并识别</button>
      </view>
    </view>

    <view class="addr-card">
      <view class="addr-title-row">
        <view class="addr-title-wrap">
          <view class="addr-bar"></view>
          <text class="addr-title">填写收货地址</text>
        </view>
        <text class="addr-link" catchtap="onChooseAddress">微信地址簿</text>
      </view>
      <view class="field">
        <text class="label">收礼人姓名</text>
        <input class="input" placeholder="收件人姓名" placeholder-class="ph" value="{{name}}" bindinput="onName" />
      </view>
      <view class="field">
        <text class="label">手机号</text>
        <input class="input" placeholder="收件人手机号" placeholder-class="ph" value="{{phone}}" bindinput="onPhone" />
      </view>
      <view class="field">
        <text class="label">收货地址</text>
        <input class="input" placeholder="省/市/区/街道/门牌号" placeholder-class="ph" value="{{address}}" bindinput="onAddr" />
      </view>
    </view>
    <view class="privacy-card">
      <view class="privacy-header">
        <text class="lock">🔒</text>
        <text class="privacy-title">地址隐私保护</text>
      </view>
      <text class="privacy-text">您填写的地址 <text class="em">仅CCG官方可见</text>，用于发货。送礼人无法查看您的任何地址信息。物流信息也只发送给您。</text>
    </view>
    <view class="submit" bindtap="onSubmit">确认填写，接收礼物</view>
    <text class="submit-hint">填写后礼物将在24小时内发出</text>
  </view>
</view>
