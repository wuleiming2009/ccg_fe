.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 98rpx;
  background: #fefaf9;
  border-top: 1rpx solid rgba(31, 42, 55, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 999;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.tab-icon-center {
  width: 74rpx;
  height: 56rpx;
  margin-bottom: 0;
  transform: translateY(-5rpx);
}

.tab-text {
  font-size: 20rpx;
  color: #666666;
}

.tab-item.active .tab-text {
  color: #ff7a3f;
}